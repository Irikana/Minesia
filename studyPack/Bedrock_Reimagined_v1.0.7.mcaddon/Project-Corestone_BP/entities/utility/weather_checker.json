{
    "format_version": "1.21.60",
    "minecraft:entity": {
        "description": {
            "identifier": "5fs_br:weather_checker",
            "is_summonable": true,
            "is_spawnable": false
        },
        "component_groups": {
            "5fs_br:despawn": {
                "minecraft:instant_despawn": {}
            }
        },
        "components": {
            "minecraft:physics": {
                "has_collision": false
            },
            "minecraft:pushable": {
                "is_pushable": false,
                "is_pushable_by_piston": false
            },
            "minecraft:navigation.float": {},
            "minecraft:collision_box": {
                "width": 0,
                "height": 0
            },
            "minecraft:health": {
                "value": 1,
                "min": 1
            },
            "minecraft:damage_sensor": {
                "triggers": {
                    "cause": "all",
                    "deals_damage": "no"
                }
            },
            "minecraft:type_family": {
                "family": [
                    "inanimate"
                ]
            },
            "minecraft:environment_sensor": {
                "triggers": [
                    {
                        "event": "5fs_br:remove_sandstorm",
                        "target": "self",
                        "filters": {
                            "test": "weather",
                            "operator": "!=",
                            "value": "thunderstorm"
                        }
                    },
                    {
                        "event": "5fs_br:start_sandstorm",
                        "target": "self",
                        "filters": {
                            "test": "weather",
                            "operator": "==",
                            "value": "thunderstorm"
                        }
                    }
                ]
            },
            "minecraft:timer": {
                "time": 0.25,
                "looping": true,
                "time_down_event": {
                    "event": "5fs_br:despawn",
                    "target": "self"
                }
            }
        },
        "events": {
            "5fs_br:start_sandstorm": {
                "queue_command": {
                    "command": [
                        "scriptevent 5fs_br:start_sandstorm"
                    ]
                },
                "add": {
                    "component_groups": [
                        "5fs_br:despawn"
                    ]
                }
            },
            "5fs_br:remove_sandstorm": {
                "queue_command": {
                    "command": [
                        "scriptevent 5fs_br:remove_sandstorm"
                    ]
                },
                "add": {
                    "component_groups": [
                        "5fs_br:despawn"
                    ]
                }
            },
            "5fs_br:despawn": {
                "add": {
                    "component_groups": [
                        "5fs_br:despawn"
                    ]
                }
            }
        }
    }
}