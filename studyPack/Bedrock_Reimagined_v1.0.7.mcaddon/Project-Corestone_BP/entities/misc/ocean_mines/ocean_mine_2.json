{
    "format_version": "1.21.60",
    "minecraft:entity": {
        "description": {
            "identifier": "5fs_br:ocean_mine_2",
            "is_summonable": true,
            "is_spawnable": false
        },
        "component_groups": {
            "5fs_br:despawn": {
                "minecraft:instant_despawn": {}
            },
            "5fs_br:explode": {
                "minecraft:behavior.knockback_roar": {
                    "priority": 0,
                    "duration": 0.83,
                    "attack_time": 0.4,
                    "knockback_damage": 4,
                    "knockback_horizontal_strength": 3,
                    "knockback_vertical_strength": 1,
                    "knockback_range": 2,
                    "cooldown_time": 10,
                    "on_roar_end": {
                        "event": "5fs_br:despawn"
                    }
                }
            },
            "5fs_br:large_variant": {
                "minecraft:variant": {
                    "value": 0
                },
                "minecraft:collision_box": {
                    "width": 2.7,
                    "height": 12.5
                }
            },
            "5fs_br:small_variant": {
                "minecraft:variant": {
                    "value": 1
                },
                "minecraft:collision_box": {
                    "width": 2.7,
                    "height": 7.5
                }
            }
        },
        "components": {
            "minecraft:type_family": {
                "family": [
                    "ocean_mine",
                    "nolife"
                ]
            },
            "minecraft:timer": {
                "looping": true,
                "time": 0.1,
                "time_down_event": {
                    "event": "5fs_br:mine",
                    "target": "self",
                    "filters": {
                        "test": "has_component",
                        "operator": "!=",
                        "value": "minecraft:behavior.knockback_roar"
                    }
                }
            },
            "minecraft:environment_sensor": {
                "triggers": [
                    {
                        "filters": {
                            "all_of": [
                                {
                                    "test": "in_water",
                                    "value": false
                                }
                            ]
                        },
                        "event": "5fs_br:despawn"
                    }
                ]
            },
            "minecraft:damage_sensor": {
                "triggers": [
                    {
                        "cause": "all",
                        "deals_damage": "no"
                    }
                ]
            },
            "minecraft:physics": {
                "has_collision": true,
                "has_gravity": true
            }
        },
        "events": {
            "5fs_br:despawn": {
                "add": {
                    "component_groups": [
                        "5fs_br:despawn"
                    ]
                }
            },
            "5fs_br:explosion": {
                "add": {
                    "component_groups": [
                        "5fs_br:explode"
                    ]
                }
            },
            "5fs_br:mine": {
                "queue_command": {
                    "command": [
                        "execute if entity @a[y=~9,r=6] run event entity @s 5fs_br:explosion",
                        "scriptevent 5fs_br:oceanMines"
                    ]
                }
            },
            "5fs_br:spawn_large": {
                "add": {
                    "component_groups": [
                        "5fs_br:large_variant"
                    ]
                }
            },
            "5fs_br:spawn_small": {
                "add": {
                    "component_groups": [
                        "5fs_br:small_variant"
                    ]
                }
            }
        }
    }
}