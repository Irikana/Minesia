{
    "format_version": "1.21.90",
    "minecraft:entity": {
        "description": {
            "identifier": "5fs_br:decorated_pot_entity",
            "is_spawnable": false,
            "is_summonable": true,
            "properties": {
                "5fs_br:decorated_pot_type_0": {
                    "client_sync": true,
                    "type": "enum",
                    "default": "none",
                    "values": [
                        "none",
                        "mossy_cobblestone",
                        "mossy_stone_brick",
                        "sandstone",
                        "mossy_cobblestone_trap",
                        "mossy_stone_brick_trap",
                        "sandstone_trap"
                    ]
                }
            },
            "animations": {
                "teleport": "animation.tile_entity.teleport"
            },
            "scripts": {
                "animate": [
                    "teleport"
                ]
            }
        },
        "component_groups": {
            "5fs_br:health": {
                "minecraft:health": {
                    "value": 1,
                    "min": 0
                }
            },
            "5fs_br:instant_despawn": {
                "minecraft:instant_despawn": {}
            }
        },
        "components": {
            "minecraft:physics": {
                "has_collision": false,
                "has_gravity": false
            },
            "minecraft:pushable": {
                "is_pushable": false,
                "is_pushable_by_piston": false
            },
            "minecraft:navigation.float": {},
            "minecraft:collision_box": {
                "width": 0.3,
                "height": 0.3
            },
            "minecraft:type_family": {
                "family": [
                    "inanimate",
					"nolife",
					"mob" //prevent waila show inventory size
                ]
            },
            "minecraft:damage_sensor": {
                "triggers": {
                    "cause": "all",
                    "deals_damage": "no"
                }
            },
            "minecraft:inventory": {
                "inventory_size": 1,
                "can_be_siphoned_from": true,
                "restrict_to_owner": true,
                "private": false,
                "container_type": "inventory"
            },
            "minecraft:fire_immune": {},
            "minecraft:on_death": {
                "event": "5fs_br:instant_despawn"
            },
            "minecraft:inside_block_notifier": {
                "block_list": [
                    {
                        "block": {
                            "name": "5fs_br:mossy_cobblestone_decorated_pot"
                        },
                        "exited_block_event": {
                            "event": "5fs_br:despawn"
                        }
                    },
                    {
                        "block": {
                            "name": "5fs_br:mossy_stone_brick_decorated_pot"
                        },
                        "exited_block_event": {
                            "event": "5fs_br:despawn"
                        }
                    },
                    {
                        "block": {
                            "name": "5fs_br:sandstone_decorated_pot"
                        },
                        "exited_block_event": {
                            "event": "5fs_br:despawn"
                        }
                    },
                    {
                        "block": {
                            "name": "5fs_br:mossy_cobblestone_trap_decorated_pot"
                        },
                        "exited_block_event": {
                            "event": "5fs_br:despawn"
                        }
                    },
                    {
                        "block": {
                            "name": "5fs_br:mossy_stone_brick_trap_decorated_pot"
                        },
                        "exited_block_event": {
                            "event": "5fs_br:despawn"
                        }
                    },
                    {
                        "block": {
                            "name": "5fs_br:sandstone_trap_decorated_pot"
                        },
                        "exited_block_event": {
                            "event": "5fs_br:despawn"
                        }
                    }
                ]
            }
        },
        "events": {
            "5fs_br:despawn": {
                "add": {
                    "component_groups": [
                        "5fs_br:health"
                    ]
                },
                "queue_command": {
                    "command": [
                        "kill @s"
                    ]
                }
            },
            "5fs_br:instant_despawn": {
                "add": {
                    "component_groups": [
                        "5fs_br:instant_despawn"
                    ]
                }
            }
        }
    }
}