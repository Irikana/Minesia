{
    "format_version": "1.21.80",
    "minecraft:entity": {
        "description": {
            "identifier": "5fs_br:clock_entity",
            "is_spawnable": false,
            "is_summonable": true,
            "is_experimental": false,
            "runtime_identifier": "minecraft:snowball",
            "properties": {
                "5fs_br:rotation": {
                    "client_sync": true,
                    "type": "enum",
                    "default": "north",
                    "values": [
                        "north",
                        "south",
                        "west",
                        "east"
                    ]
                },
                "5fs_br:legs": {
                    "client_sync": true,
                    "default": true,
                    "type": "bool"
                },
                "5fs_br:bells": {
                    "client_sync": true,
                    "default": false,
                    "type": "bool"
                }
            },
            "animations": {
                "teleport": "animation.tile_entity.teleport"
            },
            "scripts": {
                "animate": [
                    "teleport"
                ]
            }
        },
        "component_groups": {
            "5fs_br:health": {
                "minecraft:health": {
                    "value": 1,
                    "min": 0
                }
            },
            "5fs_br:instant_despawn": {
                "minecraft:instant_despawn": {}
            },
            "5fs_br:bells": {
                "minecraft:loot": {
                    "table": "loot_tables/entities/clock_with_bells.json"
                }
            }
        },
        "components": {
            "minecraft:type_family": {
                "family": [
                    "inanimate",
                    "nolife"
                ]
            },
            "minecraft:collision_box": {
                "width": 0,
                "height": 0.75
            },
            "minecraft:inside_block_notifier": {
                "block_list": [
                    {
                        "block": {
                            "name": "5fs_br:clock"
                        },
                        "exited_block_event": {
                            "event": "5fs_br:despawn",
                            "target": "self"
                        }
                    }
                ]
            },
            "minecraft:health": {
                "value": 1,
                "max": 1
            },
            "minecraft:damage_sensor": {
                "triggers": {
                    "cause": "all",
                    "deals_damage": "no"
                }
            },
            "minecraft:nameable": {
                "always_show": true
            },
            "minecraft:physics": {
                "has_collision": false,
                "has_gravity": false
            },
            "minecraft:pushable": {
                "is_pushable": false,
                "is_pushable_by_piston": false
            },
            "minecraft:loot": {
                "table": "loot_tables/entities/clock.json"
            },
            "minecraft:on_death": {
                "event": "5fs_br:instant_despawn"
            }
        },
        "events": {
            "5fs_br:despawn": {
                "add": {
                    "component_groups": [
                        "5fs_br:health"
                    ]
                },
                "queue_command": {
                    "command": [
                        "kill @s"
                    ]
                }
            },
            "5fs_br:instant_despawn": {
                "add": {
                    "component_groups": [
                        "5fs_br:instant_despawn"
                    ]
                }
            },
            "5fs_br:bells": {
                "set_property": {
                    "5fs_br:bells": true
                },
                "add": {
                    "component_groups": [
                        "5fs_br:bells"
                    ]
                }
            }
        }
    }
}