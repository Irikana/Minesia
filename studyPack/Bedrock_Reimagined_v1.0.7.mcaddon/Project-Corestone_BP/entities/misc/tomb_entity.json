{
	"format_version": "1.20.80",
	"minecraft:entity": {
		"description": {
			"identifier": "5fs_br:tomb_entity",
			"is_spawnable": false,
			"is_summonable": true,
			"is_experimental": false,
            "animations": {
                "teleport": "animation.tile_entity.teleport"
            },
            "scripts": {
                "animate": [
                    "teleport"
                ]
            }
		},
		"components": {
			"minecraft:type_family": {
				"family": [
					"inanimate", 
					"nolife",
					"mob" //prevent waila show inventory size
				]
			},
			"minecraft:collision_box": {
				"width": 0.0,
				"height": 0.0
			},
			"minecraft:health": {
				"value": 1,
				"max": 1
			},
			"minecraft:inventory": {
				"can_be_siphoned_from": false,
				"container_type": "inventory",
				"inventory_size": 256,
				"restrict_to_owner": true
			},
			"minecraft:damage_sensor": {
				"triggers": {
					"cause": "all",
					"deals_damage": false
				}
			},
			"minecraft:nameable": {
                "always_show": true
            },
			"minecraft:physics": {
				"has_collision": false,
				"has_gravity": false
			},
			"minecraft:pushable": {
				"is_pushable": false,
				"is_pushable_by_piston": false
			},
			"minecraft:persistent": {}
		}
	}
}
