{
	"format_version": "1.21.60",
	"minecraft:entity": {
		"description": {
			"identifier": "5fs_br:sandstone_dispenser_entity",
			"is_spawnable": false,
			"is_summonable": true,
            "animations": {
                "teleport": "animation.tile_entity.teleport"
            },
            "scripts": {
                "animate": [
                    "teleport"
                ]
            }
		},
		"component_groups": {
			"5fs_br:health": {
				"minecraft:health": {
					"value": 1,
					"min": 0
				}
			},
			"5fs_br:instant_despawn": {
				"minecraft:instant_despawn": {}
			},
			"5fs_br:compact": {
				"minecraft:collision_box": {
					"width": 0.5,
					"height": 0.5
				},
				"minecraft:timer": {
					"time": 0.1,
					"time_down_event": {
						"event": "5fs_br:normal"
					}
				}
			},
			"5fs_br:normal": {
				"minecraft:collision_box": {
					"width": 1,
					"height": 1
				}
			}
		},
		"components": {
			"minecraft:damage_sensor": {
				"triggers": {
					"cause": "all",
					"deals_damage": "no"
				}
			},
			"minecraft:type_family": {
				"family": [
					"inanimate",
					"dropper",
					"tile_break",
					"nolife"
				]
			},
			"minecraft:health": {
				"value": 1,
				"max": 1,
				"min": 1
			},
			"minecraft:knockback_resistance": {
				"value": 100,
				"max": 100
			},
			"minecraft:inventory": {
				"container_type": "container",
				"inventory_size": 19
			},
			"minecraft:pushable": {
				"is_pushable": false,
				"is_pushable_by_piston": false
			},
			"minecraft:physics": {
				"has_gravity": false,
				"has_collision": false
			},
			"minecraft:entity_sensor": {
				"subsensors": [
					{
						"range": [
							7,
							7
						],
						"cooldown": 0,
						"minimum_count": 1,
						"event_filters": {
							"any_of": [
								{
									"test": "is_sneaking",
									"subject": "other",
									"operator": "==",
									"value": true
								},
								{
									"test": "has_equipment_tag",
									"subject": "other",
									"operator": "==",
									"domain": "hand",
									"value": "minecraft:is_pickaxe"
								}
							]
						},
						"event": "5fs_br:compact"
					},
                    {
                        "range": [
                            3,
                            3
                        ],
                        "cooldown": 15,
                        "minimum_count": 1,
                        "event_filters": {
                            "test": "is_family",
                            "subject": "other",
                            "value": "player"
                        },
                        "event": "5fs_br:hint"
                    }
				]
			},
			"minecraft:inside_block_notifier": {
				"block_list": [
					{
						"block": {
							"name": "5fs_br:sandstone_dispenser"
						},
						"exited_block_event": {
							"event": "5fs_br:despawn"
						}
					}
				]
			}
		},
		"events": {
            "5fs_br:hint": {
                "queue_command": {
                    "command": [
                        "scriptevent 5fs_br:tile_entity_hint"
                    ]
                }
            },
			"minecraft:entity_spawned": {
                "add": { "component_groups": ["5fs_br:normal"] }
            },
			"5fs_br:despawn": {
				"add": {
					"component_groups": [
						"5fs_br:health"
					]
				},
				"queue_command": {
					"command": [
						"kill @s",
                        "event entity @s 5fs_br:instant_despawn"
					]
				}
			},
			"5fs_br:instant_despawn": {
				"add": {
					"component_groups": ["5fs_br:instant_despawn"]
				}
			},
			"5fs_br:compact": {
				"add": {
					"component_groups": [
						"5fs_br:compact"
					]
				}
			},
			"5fs_br:normal": {
				"remove": {
					"component_groups": [
						"5fs_br:compact"
					]
				},
				"add": {
					"component_groups": [
						"5fs_br:normal"
					]
				}
			}
		}
	}
}