                                    {
                                        "test": "bool_property",
                                        "domain": "5fs_br:is_opened",
                                        "value": true
                                    }
                                ]
                            },
                            "range": [
                                5,
                                5
                            ],
                            "cooldown": 0.1
                        },
                        {
                            "range": [
                                7,
