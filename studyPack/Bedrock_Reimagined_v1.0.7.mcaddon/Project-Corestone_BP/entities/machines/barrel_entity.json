                                "all_of": [
                                    {
                                        "test": "has_container_open",
                                        "operator": "==",
                                        "subject": "other",
                                        "value": true
                                    },
                                    {
                                        "test": "bool_property",
                                        "domain": "5fs_br:is_opened",
                                        "value": false
