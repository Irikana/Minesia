                    "component_groups": [
                        "5fs_br:closing"
                    ]
                }
            },
            "5fs_br:open": {
                "queue_command": {
                    "command": [
                        "scriptevent 5fs_br:barrel_open"
                    ]
                },
                "remove": {
                    "component_groups": [
                        "5fs_br:closing"
                    ]
                },
                "set_property": {
                    "5fs_br:is_opened": true
                }
            },
            "5fs_br:close": {
                "remove": {
                    "component_groups": [
                        "5fs_br:open_close"
                    ]
                },
                "add": {
                    "component_groups": [
                        "5fs_br:closing",
                        "5fs_br:closed"
                    ]
                },
                "set_property": {
                    "5fs_br:is_opened": false
                }
