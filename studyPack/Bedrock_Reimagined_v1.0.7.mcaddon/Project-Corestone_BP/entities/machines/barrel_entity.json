                    ]
                }
            },
            "5fs_br:despawn": {
                "add": {
                    "component_groups": [
                        "5fs_br:health"
                    ]
                },
                "queue_command": {
                    "command": [
                        "kill @s",
                        "event entity @s 5fs_br:instant_despawn"
                    ]
                }
            },
            "5fs_br:instant_despawn": {
                "add": {
                    "component_groups": [
                        "5fs_br:instant_despawn"
                    ]
                }
            },
            "minecraft:entity_spawned": {
                "add": {
                    "component_groups": [
                        "5fs_br:normal",
                        "5fs_br:closed"
                    ]
                }
            },
            "5fs_br:compact": {
                "add": {
                    "component_groups": [
                        "5fs_br:compact"
                    ]
                }
            },
            "5fs_br:normal": {
                "remove": {
                    "component_groups": [
                        "5fs_br:compact"
                    ]
                },
                "add": {
                    "component_groups": [
                        "5fs_br:normal"
                    ]
                }
            },
