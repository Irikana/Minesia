{
    "format_version": "1.21.60",
    "minecraft:entity": {
        "description": {
            "identifier": "5fs_br:item_node_entity",
            "is_summonable": true,
            "animations": {
                "teleport": "animation.tile_entity.teleport"
            },
            "scripts": {
                "animate": [
                    "teleport"
                ]
            }
        },
        "component_groups": {
            "5fs_br:health": {
                "minecraft:health": {
                    "value": 1,
                    "min": 0
                }
            },
            "5fs_br:instant_despawn": {
                "minecraft:instant_despawn": {}
            }
        },
        "components": {
            "minecraft:damage_sensor": {
                "triggers": {
                    "cause": "all",
                    "deals_damage": "no"
                }
            },
            "minecraft:type_family": {
                "family": [
                    "inanimate",
                    "smelter",
                    "nolife"
                ]
            },
            "minecraft:collision_box": {
                "width": 0.2,
                "height": 0.2
            },
            "minecraft:health": {
                "value": 1,
                "max": 1,
                "min": 1
            },
            "minecraft:knockback_resistance": {
                "value": 100,
                "max": 100
            },
            "minecraft:inventory": {
                "container_type": "container",
                "inventory_size": 6,
                "restrict_to_owner": true
            },
            "minecraft:pushable": {
                "is_pushable": false,
                "is_pushable_by_piston": false
            },
            "minecraft:physics": {
                "has_gravity": false,
                "has_collision": false
            },
            "minecraft:on_death": {
                "event": "5fs_br:instant_despawn"
            },
            "minecraft:inside_block_notifier": {
                "block_list": [
                    {
                        "block": {
                            "name": "5fs_br:item_node"
                        },
                        "exited_block_event": {
                            "event": "5fs_br:despawn"
                        }
                    },
                    {
                        "block": {
                            "name": "5fs_br:exposed_copper_item_node"
                        },
                        "exited_block_event": {
                            "event": "5fs_br:despawn"
                        }
                    },
                    {
                        "block": {
                            "name": "5fs_br:weathered_copper_item_node"
                        },
                        "exited_block_event": {
                            "event": "5fs_br:despawn"
                        }
                    },
                    {
                        "block": {
                            "name": "5fs_br:copper_item_node"
                        },
                        "exited_block_event": {
                            "event": "5fs_br:despawn"
                        }
                    },
                    {
                        "block": {
                            "name": "5fs_br:oxidized_copper_item_node"
                        },
                        "exited_block_event": {
                            "event": "5fs_br:despawn"
                        }
                    },
                    {
                        "block": {
                            "name": "5fs_br:waxed_exposed_copper_item_node"
                        },
                        "exited_block_event": {
                            "event": "5fs_br:despawn"
                        }
                    },
                    {
                        "block": {
                            "name": "5fs_br:waxed_weathered_copper_item_node"
                        },
                        "exited_block_event": {
                            "event": "5fs_br:despawn"
                        }
                    },
                    {
                        "block": {
                            "name": "5fs_br:waxed_copper_item_node"
                        },
                        "exited_block_event": {
                            "event": "5fs_br:despawn"
                        }
                    },
                    {
                        "block": {
                            "name": "5fs_br:waxed_oxidized_copper_item_node"
                        },
                        "exited_block_event": {
                            "event": "5fs_br:despawn"
                        }
                    }
                ]
            }
        },
        "events": {
            "5fs_br:despawn": {
                "add": {
                    "component_groups": [
                        "5fs_br:health"
                    ]
                },
                "queue_command": {
                    "command": [
                        "kill @s",
                        "event entity @s 5fs_br:instant_despawn"
                    ]
                }
            },
            "5fs_br:instant_despawn": {
                "add": {
                    "component_groups": [
                        "5fs_br:instant_despawn"
                    ]
                }
            }
        }
    }
}