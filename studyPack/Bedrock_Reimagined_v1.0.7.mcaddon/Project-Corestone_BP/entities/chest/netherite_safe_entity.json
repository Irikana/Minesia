{
    "format_version": "1.21.60",
    "minecraft:entity": {
        "description": {
            "identifier": "5fs_br:netherite_safe_entity",
            "is_summonable": true,
            "properties": {
                "5fs_br:rotation": {
                    "client_sync": true,
                    "type": "enum",
                    "default": "north",
                    "values": [
                        "north",
                        "south",
                        "west",
                        "east"
                    ]
                },
                "5fs_br:is_opened": {
                    "client_sync": true,
                    "type": "bool",
                    "default": false
                }
            },
            "animations": {
                "teleport": "animation.tile_entity.teleport"
            },
            "scripts": {
                "animate": [
                    "teleport"
                ]
            }
        },
        "component_groups": {
            "5fs_br:health": {
                "minecraft:health": {
                    "value": 1,
                    "min": 0
                }
            },
            "5fs_br:instant_despawn": {
                "minecraft:instant_despawn": {}
            },
            "5fs_br:open_close": {
                "minecraft:entity_sensor": {
                    "relative_range": true,
                    "subsensors": [
                        {
                            "event": "5fs_br:open",
                            "maximum_count": 1,
                            "minimum_count": 1,
                            "event_filters": {
                                "all_of": [
                                    {
                                        "test": "has_container_open",
                                        "operator": "==",
                                        "subject": "other",
                                        "value": true
                                    },
                                    {
                                        "test": "bool_property",
                                        "domain": "5fs_br:is_opened",
                                        "value": false
                                    }
                                ]
                            },
                            "range": [
                                5,
                                5
                            ],
                            "cooldown": 0.1
                        },
                        {
                            "event": "5fs_br:close",
                            "maximum_count": 1,
                            "minimum_count": 1,
                            "event_filters": {
                                "all_of": [
                                    {
                                        "test": "has_container_open",
                                        "operator": "==",
                                        "subject": "other",
                                        "value": false
                                    },
                                    {
                                        "test": "bool_property",
                                        "domain": "5fs_br:is_opened",
                                        "value": true
                                    }
                                ]
                            },
                            "range": [
                                5,
                                5
                            ],
                            "cooldown": 0.1
                        },
                        {
                            "range": [
                                7,
                                7
                            ],
                            "cooldown": 0,
                            "minimum_count": 1,
                            "event_filters": {
                                "any_of": [
                                    {
                                        "test": "is_sneaking",
                                        "subject": "other",
                                        "operator": "==",
                                        "value": true
                                    },
                                    {
                                        "test": "has_equipment_tag",
                                        "subject": "other",
                                        "operator": "==",
                                        "domain": "hand",
                                        "value": "minecraft:is_pickaxe"
                                    }
                                ]
                            },
                            "event": "5fs_br:compact"
                        },
                        {
                            "range": [
                                7,
                                7
                            ],
                            "cooldown": 15,
                            "minimum_count": 1,
                            "event_filters": {
                                "test": "is_family",
                                "subject": "other",
                                "value": "player"
                            },
                            "event": "5fs_br:hint"
                        }
                    ]
                }
            },
            "5fs_br:closing": {
                "minecraft:behavior.timer_flag_1": {
                    "cooldown_range": 0,
                    "duration_range": 0.74,
                    "on_end": {
                        "event": "5fs_br:closed"
                    }
                }
            },
            "5fs_br:compact": {
                "minecraft:collision_box": {
                    "width": 0.5,
                    "height": 0.5
                },
                "minecraft:timer": {
                    "time": 0.1,
                    "time_down_event": {
                        "event": "5fs_br:normal"
                    }
                }
            },
            "5fs_br:normal": {
                "minecraft:collision_box": {
                    "width": 1,
                    "height": 1
                }
            }
        },
        "components": {
            "minecraft:damage_sensor": {
                "triggers": {
                    "cause": "all",
                    "deals_damage": "no"
                }
            },
            "minecraft:type_family": {
                "family": [
                    "5fs_br:tile_entity",
                    "inanimate",
                    "nolife"
                ]
            },
            "minecraft:rotation_axis_aligned": {},
            "minecraft:body_rotation_blocked": {},
            "minecraft:nameable": {
                "allow_name_tag_renaming": false,
                "always_show": false
            },
            "minecraft:collision_box": {
                "width": 0.1,
                "height": 0.1
            },
            "minecraft:custom_hit_test": {
                "hitboxes": [
                    {
                        "width": 1,
                        "height": 0.5,
                        "pivot": [
                            0,
                            0.255,
                            0
                        ]
                    }
                ]
            },
            "minecraft:health": {
                "value": 1,
                "min": 1
            },
            "minecraft:fire_immune": {},
            "minecraft:knockback_resistance": {
                "value": 100,
                "max": 100
            },
            "minecraft:inventory": {
                "container_type": "container",
                "inventory_size": 27,
                "can_be_siphoned_from": true
            },
            "minecraft:pushable": {
                "is_pushable": false,
                "is_pushable_by_piston": false
            },
            "minecraft:physics": {
                "has_gravity": false,
                "has_collision": false
            },
            "minecraft:inside_block_notifier": {
                "block_list": [
                    {
                        "block": {
                            "name": "5fs_br:netherite_safe"
                        },
                        "exited_block_event": {
                            "event": "5fs_br:despawn"
                        }
                    }
                ]
            },
            "minecraft:on_death": {
                "event": "5fs_br:instant_despawn"
            }
        },
        "events": {
            "5fs_br:hint": {
                "queue_command": {
                    "command": [
                        "scriptevent 5fs_br:tile_entity_hint"
                    ]
                }
            },
            "minecraft:entity_spawned": {
                "remove": {
                    "component_groups": [
                        "5fs_br:closing"
                    ]
                },
                "add": {
                    "component_groups": [
                        "5fs_br:normal"
                    ]
                }
            },
            "5fs_br:despawn": {
                "add": {
                    "component_groups": [
                        "5fs_br:health"
                    ]
                },
                "queue_command": {
                    "command": [
                        "kill @s"
                    ]
                }
            },
            "5fs_br:instant_despawn": {
                "add": {
                    "component_groups": [
                        "5fs_br:instant_despawn"
                    ]
                }
            },
            "5fs_br:open": {
                "remove": {
                    "component_groups": [
                        "5fs_br:closing"
                    ]
                },
                "set_property": {
                    "5fs_br:is_opened": true
                }
            },
            "5fs_br:close": {
                "remove": {
                    "component_groups": [
                        "5fs_br:open_close"
                    ]
                },
                "add": {
                    "component_groups": [
                        "5fs_br:closing"
                    ]
                },
                "set_property": {
                    "5fs_br:is_opened": false
                }
            },
            "5fs_br:open_close": {
                "add": {
                    "component_groups": [
                        "5fs_br:open_close"
                    ]
                }
            },
            "5fs_br:compact": {
                "add": {
                    "component_groups": [
                        "5fs_br:compact"
                    ]
                }
            },
            "5fs_br:normal": {
                "remove": {
                    "component_groups": [
                        "5fs_br:compact"
                    ]
                },
                "add": {
                    "component_groups": [
                        "5fs_br:normal"
                    ]
                }
            },
            "5fs_br:closed": {
                "remove": {
                    "component_groups": [
                        "5fs_br:closing"
                    ]
                }
            }
        }
    }
}