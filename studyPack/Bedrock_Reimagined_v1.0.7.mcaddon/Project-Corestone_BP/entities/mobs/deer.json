            },
            "minecraft:ageable_grow_up": {
                "remove": {
                    "component_groups": [
                        "5fs_br:deer_baby"
                    ]
                },
                "add": {
                    "component_groups": [
                        "5fs_br:awake",
                        "5fs_br:deer_adult"
                    ]
                }
            },
            "minecraft:spawn_adult": {
                "sequence": [
                    {
                        "filters": {
                            "test": "has_biome_tag",
                            "value": "redwood_forest"
                        },
                        "add": {
                            "component_groups": [
                                "5fs_br:awake",
                                "5fs_br:redwood_variant",
                                "5fs_br:deer_adult"
                            ]
