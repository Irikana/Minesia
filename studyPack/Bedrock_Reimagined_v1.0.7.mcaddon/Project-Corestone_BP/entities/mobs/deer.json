                    "sprint_speed_multiplier": 0.85,
                    "priority": 3,
                    "entity_types": {
                        "filters": {
                            "all_of": [
                                {
                                    "test": "is_family",
                                    "subject": "other",
                                    "value": "player"
                                },
                                {
                                    "test": "is_sneaking",
                                    "subject": "other",
                                    "value": false
                                }
                            ]
                        }
                    }
                },
