                        },
                        "add": {
                            "component_groups": [
                                "5fs_br:redwood_variant",
                                "5fs_br:awake",
                                "5fs_br:deer_baby"
                            ]
                        }
                    },
                    {
                        "filters": {
                            "test": "has_biome_tag",
                            "operator": "!=",
                            "value": "redwood_forest"
