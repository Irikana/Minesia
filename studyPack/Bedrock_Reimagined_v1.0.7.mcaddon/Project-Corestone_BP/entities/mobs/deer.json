                    "damage": 6
                },
                "minecraft:health": {
                    "value": 48,
                    "max": 48
                },
                "minecraft:movement": {
                    "value": 2.5
                },
                "minecraft:scale": {
                    "value": 2.5
                },
                "minecraft:loot": {
                    "table": "loot_tables/entities/redwood_deer.json"
                }
            },
            "5fs_br:deer_baby": {
                "minecraft:is_baby": {},
                "minecraft:ageable": {
                    "duration": 1200,
                    "feed_items": "5fs_br:acorn",
