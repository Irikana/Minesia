                "minecraft:environment_sensor": {
                    "triggers": [
                        {
                            "event": "5fs_br:sleep",
                            "target": "self",
                            "filters": {
                                "all_of": [
                                    {
                                        "test": "is_daytime",
                                        "value": false
                                    },
                                    {
                                        "test": "has_component",
                                        "operator": "!=",
                                        "value": "minecraft:is_baby"
                                    },
                                    {
                                        "test": "has_target",
                                        "value": false
                                    },
                                    {
                                        "test": "is_avoiding_mobs",
                                        "value": false
                                    }
                                ]
                            }
                        },
                        {
                            "event": "5fs_br:sleep",
                            "target": "self",
                            "filters": {
                                "all_of": [
                                    {
                                        "test": "is_daytime",
                                        "value": false
                                    },
                                    {
                                        "test": "has_component",
                                        "operator": "==",
                                        "value": "minecraft:is_baby"
                                    },
                                    {
                                        "test": "is_avoiding_mobs",
                                        "value": false
                                    }
                                ]
                            }
                        }
                    ]
                }
            },
            "5fs_br:sleeping": {
