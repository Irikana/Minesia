                "randomize": [
                    {
                        "weight": 95,
                        "trigger": "minecraft:spawn_adult"
                    },
                    {
                        "weight": 5,
                        "add": {
                            "component_groups": [
                                "5fs_br:awake",
                                "5fs_br:deer_baby"
                            ]
                        },
                        "sequence": [
                            {
                                "filters": {
                                    "test": "has_biome_tag",
                                    "value": "redwood_forest"
                                },
                                "add": {
                                    "component_groups": [
                                        "5fs_br:redwood_variant",
                                        "5fs_br:awake",
                                        "5fs_br:deer_baby"
                                    ]
                                }
                            }
                        ]
                    }
                ]
            },
            "minecraft:entity_born": {
                "sequence": [
                    {
                        "filters": {
                            "test": "has_biome_tag",
