        "remove": {
          "component_groups": [
            "5fs_br:building_dam"
          ]
        }
      },
      "5fs_br:become_calm": {
        "sequence": [
          {
            "filters": {
              "test": "has_component",
              "operator": "==",
              "value": "minecraft:timer"
            },
            "remove": {
              "component_groups": [
                "5fs_br:angry"
              ]
            },
            "reset_target": {}
          },
          {
            "filters": {
              "test": "has_component",
              "operator": "!=",
              "value": "minecraft:timer"
            },
            "remove": {
              "component_groups": [
                "5fs_br:angry"
              ]
            },
            "add": {
              "component_groups": [
                "5fs_br:look_for_log"
              ]
            },
            "reset_target": {}
          }
        ]
      },
      "5fs_br:become_angry": {
        "remove": {
          "component_groups": [
            "5fs_br:look_for_log",
            "5fs_br:eating_log",
            "5fs_br:building_dam"
          ]
        },
        "add": {
          "component_groups": [
            "5fs_br:angry"
          ]
        }
      },
      "5fs_br:normal_scale": {
        "remove": {
          "component_groups": [
            "5fs_br:shrinkify",
            "5fs_br:gigantify"
          ]
        },
        "add": {
          "component_groups": [
            "5fs_br:normal_scale"
          ]
        }
      },
      "5fs_br:gigantify": {
        "remove": {
          "component_groups": [
            "5fs_br:shrinkify",
            "5fs_br:normal_scale"
          ]
        },
        "add": {
          "component_groups": [
            "5fs_br:gigantify"
          ]
        }
      },
      "5fs_br:shrinkify": {
        "remove": {
          "component_groups": [
            "5fs_br:gigantify",
            "5fs_br:normal_scale"
          ]
        },
        "add": {
          "component_groups": [
            "5fs_br:shrinkify"
          ]
        }
      },
      "5fs_br:no_fall_damage_jelly": {
        "add": {
          "component_groups": [
            "5fs_br:no_fall_damage_jelly"
          ]
        }
      },
      "5fs_br:fall_damage_jelly": {
        "remove": {
          "component_groups": [
            "5fs_br:no_fall_damage_jelly"
          ]
        }
      }
