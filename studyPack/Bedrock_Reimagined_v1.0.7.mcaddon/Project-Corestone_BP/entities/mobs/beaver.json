          },
          {
            "filters": {
              "all_of": [
                {
                  "test": "is_family",
                  "subject": "other",
                  "value": "fish"
                },
                {
                  "test": "has_component",
                  "operator": "!=",
                  "subject": "self",
                  "value": "minecraft:angry"
