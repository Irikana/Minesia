            "event": "5fs_br:finish_eating_log"
          }
        }
      },
      "5fs_br:go_build_dam": {
        "minecraft:behavior.move_to_water": {
          "goal_radius": 0,
          "search_count": 32,
          "search_height": 16,
          "search_range": 32,
          "speed_multiplier": 1,
          "priority": 1
        },
        "minecraft:timer": {
          "time": 5,
          "looping": true,
          "time_down_event": {
            "event": "5fs_br:build_dam",
            "target": "self",
            "filters": {
              "all_of": [
                {
                  "test": "in_water",
                  "value": true
                },
                {
                  "test": "has_component",
                  "operator": "!=",
                  "value": "minecraft:angry"
                }
              ]
            }
          }
        },
        "minecraft:behavior.look_at_player": {
          "priority": 12,
          "target_distance": 6,
          "probability": 0.02
        }
      },
      "5fs_br:building_dam": {
        "minecraft:movement": {
          "value": 0
        },
        "minecraft:underwater_movement": {
          "value": 0
        },
        "minecraft:behavior.timer_flag_2": {
          "cooldown_range": 0,
          "duration_range": 3.5,
          "on_end": {
            "event": "5fs_br:finish_building_dam"
          }
        }
      },
      "5fs_br:angry": {
        "minecraft:movement": {
          "value": 0.125
        },
        "minecraft:underwater_movement": {
          "value": 0.15
        },
        "minecraft:angry": {
          "duration": 20,
          "calm_event": {
            "event": "5fs_br:become_calm",
