    "events": {
      "minecraft:entity_spawned": {
        "add": {
          "component_groups": [
            "5fs_br:look_for_log",
            "5fs_br:default_movement"
          ]
        }
      },
      "5fs_br:start_eating_log": {
        "remove": {
          "component_groups": [
            "5fs_br:look_for_log"
          ]
        },
        "add": {
          "component_groups": [
            "5fs_br:eating_log"
          ]
        }
      },
      "5fs_br:finish_eating_log": {
        "queue_command": {
          "command": [
            "scriptevent 5fs_br:beaver_eat_log"
          ]
        },
        "add": {
          "component_groups": [
            "5fs_br:default_movement",
            "5fs_br:go_build_dam"
          ]
        },
        "remove": {
          "component_groups": [
            "5fs_br:eating_log"
          ]
        }
      },
      "5fs_br:go_build_dam": {
        "add": {
          "component_groups": [
            "5fs_br:go_build_dam"
          ]
        }
      },
      "5fs_br:build_dam": {
        "queue_command": {
          "command": [
            "scriptevent 5fs_br:beaver_check_for_dams"
          ]
        }
      },
      "5fs_br:start_building_dam": {
        "remove": {
          "component_groups": [
            "5fs_br:go_build_dam"
          ]
        },
        "add": {
          "component_groups": [
            "5fs_br:building_dam"
          ]
        }
      },
      "5fs_br:finish_building_dam": {
        "queue_command": {
          "command": [
            "scriptevent 5fs_br:beaver_build_dam"
          ]
