        "minecraft:health": {
          "max": 40
        },
        "minecraft:scale": {
          "value": 2
        }
      },
      "5fs_br:normal_scale": {
        "minecraft:movement": {
          "value": 0.13
        },
        "minecraft:health": {
          "max": 20
        },
        "minecraft:scale": {
          "value": 1
        }
