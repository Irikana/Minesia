        "add": {
          "component_groups": [
            "5fs_br:normal_scale"
          ]
        }
      },
      "5fs_br:gigantify": {
        "remove": {
          "component_groups": [
            "5fs_br:shrinkify",
            "5fs_br:normal_scale"
          ]
