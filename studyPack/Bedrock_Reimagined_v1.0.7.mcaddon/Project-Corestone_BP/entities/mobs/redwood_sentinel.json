    "events": {
      "minecraft:entity_spawned": {
        "filters": {
          "test": "has_biome_tag",
          "value": "redwood_forest"
        },
        "add": {
          "component_groups": [
            "5fs_br:redwood_variant"
          ]
        }
      },
      "5fs_br:attack": {
        "randomize": [
          {
            "add": {
              "component_groups": [
                "5fs_br:branch_swipe"
              ]
            },
            "weight": 1
          },
          {
            "add": {
              "component_groups": [
                "5fs_br:ground_pound"
              ]
            },
            "weight": 1
          }
        ]
      },
      "5fs_br:attacked": {
        "remove": {
          "component_groups": [
            "5fs_br:branch_swipe",
            "5fs_br:ground_pound"
          ]
        }
      },
      "5fs_br:normal_scale": {
        "remove": {
          "component_groups": [
            "5fs_br:shrinkify",
            "5fs_br:gigantify"
          ]
