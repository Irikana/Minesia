      },
      "5fs_br:normal_scale": {
        "minecraft:movement": {
          "value": 0.25
        },
        "minecraft:health": {
          "max": 8
        },
        "minecraft:scale": {
          "value": 1
        }
      },
      "5fs_br:no_fall_damage_jelly": {
        "minecraft:damage_sensor": {
          "triggers": {
            "cause": "fall",
            "deals_damage": false
          }
        }
