{
  "format_version": "1.26.0",
  "minecraft:entity": {
    "description": {
      "identifier": "minecraft:tadpole",
      "spawn_category": "creature",
      "is_spawnable": true,
      "is_summonable": true
    },
    "component_groups": {
      "grow_up": {
        "minecraft:transformation": {
          "into": "minecraft:frog",
          "transformation_sound": "convert_to_frog"
        }
      },
      "5fs_br:shrinkify": {
        "minecraft:movement": {
          "value": 0.2
        },
        "minecraft:health": {
          "max": 10
        },
        "minecraft:scale": {
          "value": 0.25
        }
      },
      "5fs_br:gigantify": {
        "minecraft:movement": {
          "value": 0.08
        },
        "minecraft:health": {
          "max": 40
        },
        "minecraft:scale": {
          "value": 2
        }
      },
      "5fs_br:normal_scale": {
        "minecraft:movement": {
          "value": 0.1
        },
        "minecraft:health": {
          "max": 20
        },
        "minecraft:scale": {
          "value": 1
        }
      },
      "5fs_br:no_fall_damage_jelly": {
        "minecraft:damage_sensor": {
          "triggers": {
            "cause": "fall",
            "deals_damage": "no"
          }
        }
      }
    },
    "components": {
      "minecraft:is_hidden_when_invisible": {},
      "minecraft:type_family": {
        "family": [
          "aquatic",
          "tadpole",
          "mob"
        ]
      },
      "minecraft:collision_box": {
        "width": 0.8,
        "height": 0.6
      },
      "minecraft:breathable": {
        "total_supply": 8,
        "suffocate_time": 0,
        "breathes_water": true,
        "breathes_air": false,
        "generates_bubbles": false
      },
      "minecraft:nameable": {},
      "minecraft:health": {
        "value": 6
      },
      "minecraft:hurt_on_condition": {
        "damage_conditions": [
          {
            "filters": {
              "test": "in_lava",
              "subject": "self",
              "operator": "==",
              "value": true
            },
            "cause": "lava",
            "damage_per_tick": 4
          }
        ]
      },
      "minecraft:navigation.generic": {
        "can_path_over_water": true,
        "can_swim": true,
        "can_walk": false,
        "can_sink": false,
        "avoid_damage_blocks": true
      },
      "minecraft:movement.sway": { //This is needed to allow the tadpole to swim
        "sway_amplitude": 0
      },
      "minecraft:movement": {
        "value": 0.1
      },
      "minecraft:underwater_movement": {
        "value": 0.1
      },
      "minecraft:physics": {},
      "minecraft:pushable": {},
      "minecraft:despawn": {
        "despawn_from_distance": {}
      },
      "minecraft:is_baby": {},
      "minecraft:ageable": {
        "duration": 1200,
        "feed_items": [
          "slime_ball"
        ],
        "grow_up": {
          "event": "ageable_grow_up",
          "target": "self"
        }
      },
      "minecraft:behavior.panic": {
        "priority": 1,
        "speed_multiplier": 2
      },
      "minecraft:behavior.tempt": {
        "priority": 5,
        "speed_multiplier": 1.25,
        "can_tempt_vertically": true,
        "items": [
          "slime_ball"
        ]
      },
      "minecraft:behavior.random_swim": {
        "priority": 2,
        "interval": 100
      },
      "minecraft:behavior.look_at_player": {
        "priority": 3,
        "look_distance": 6,
        "probability": 0.02
      }
    },
    "events": {
      "ageable_grow_up": {
        "sequence": [
          {
            "add": {
              "component_groups": [
                "grow_up"
              ]
            }
          }
        ]
      },
      "5fs_br:normal_scale": {
        "remove": {
          "component_groups": [
            "5fs_br:shrinkify",
            "5fs_br:gigantify"
          ]
        },
        "add": {
          "component_groups": [
            "5fs_br:normal_scale"
          ]
        }
      },
      "5fs_br:gigantify": {
        "remove": {
          "component_groups": [
            "5fs_br:shrinkify",
            "5fs_br:normal_scale"
          ]
        },
        "add": {
          "component_groups": [
            "5fs_br:gigantify"
          ]
        }
      },
      "5fs_br:shrinkify": {
        "remove": {
          "component_groups": [
            "5fs_br:gigantify",
            "5fs_br:normal_scale"
          ]
        },
        "add": {
          "component_groups": [
            "5fs_br:shrinkify"
          ]
        }
      },
      "5fs_br:no_fall_damage_jelly": {
        "add": {
          "component_groups": [
            "5fs_br:no_fall_damage_jelly"
          ]
        }
      },
      "5fs_br:fall_damage_jelly": {
        "remove": {
          "component_groups": [
            "5fs_br:no_fall_damage_jelly"
          ]
        }
      }
    }
  }
}