      "minecraft:nameable": {},
      "minecraft:behavior.avoid_mob_type": {
        "priority": 2,
        "max_dist": 16,
        "max_flee": 20,
        "entity_types": [
          {
            "filters": {
              "test": "is_family",
              "operator": "==",
              "subject": "other",
              "value": "ocean_mine"
            },
            "max_dist": 20,
            "sprint_speed_multiplier": 1
          }
        ]
      },
      "minecraft:type_family": {
