        "minecraft:scale": {
          "value": 0.5
        }
      },
      "minecraft:squid_adult": {
        "minecraft:leashable_to": {}
      },
      "5fs_br:shrinkify": {
        "minecraft:movement": {
          "value": 0.4
        },
        "minecraft:health": {
          "max": 5
        },
        "minecraft:scale": {
          "value": 0.25
        }
      },
      "5fs_br:gigantify": {
        "minecraft:movement": {
          "value": 0.16
        },
        "minecraft:health": {
          "max": 20
        },
        "minecraft:scale": {
          "value": 2
        }
      },
      "5fs_br:normal_scale": {
        "minecraft:movement": {
          "value": 0.2
