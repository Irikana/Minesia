          "aquatic",
          "squid",
          "mob"
        ]
      },
      "minecraft:collision_box": {
        "width": 0.8,
        "height": 0.8
      },
      "minecraft:health": {
        "value": 10,
        "max": 10
      },
      "minecraft:hurt_on_condition": {
        "damage_conditions": [
          {
            "filters": {
              "test": "in_lava",
              "subject": "self"
            },
            "cause": "lava",
            "damage_per_tick": 4
          }
        ]
      },
      "minecraft:loot": {
        "table": "loot_tables/entities/squid.json"
