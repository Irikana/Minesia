        "add": {
          "component_groups": [
            "5fs_br:normal_scale"
          ]
        }
      },
      "5fs_br:gigantify": {
        "remove": {
          "component_groups": [
            "5fs_br:shrinkify",
            "5fs_br:normal_scale"
          ]
        },
        "add": {
          "component_groups": [
            "5fs_br:gigantify"
          ]
        }
      },
      "5fs_br:shrinkify": {
        "remove": {
          "component_groups": [
            "5fs_br:gigantify",
            "5fs_br:normal_scale"
          ]
        },
        "add": {
          "component_groups": [
            "5fs_br:shrinkify"
          ]
        }
      },
      "5fs_br:no_fall_damage_jelly": {
        "add": {
          "component_groups": [
            "5fs_br:no_fall_damage_jelly"
          ]
        }
      },
      "5fs_br:fall_damage_jelly": {
        "remove": {
          "component_groups": [
            "5fs_br:no_fall_damage_jelly"
          ]
        }
      }
    }
