    "events": {
      "minecraft:entity_spawned": {
        "randomize": [
          {
            "weight": 95,
            "add": {
              "component_groups": [
                "minecraft:squid_adult"
              ]
            }
          },
          {
            "weight": 5,
            "add": {
              "component_groups": [
                "minecraft:squid_baby"
              ]
            }
          }
        ]
      },
      "5fs_br:normal_scale": {
        "remove": {
          "component_groups": [
            "5fs_br:shrinkify",
            "5fs_br:gigantify"
          ]
