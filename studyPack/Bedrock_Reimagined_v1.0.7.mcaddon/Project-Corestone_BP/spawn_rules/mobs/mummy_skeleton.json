        "minecraft:weight": { "default": 14 },
        "minecraft:herd": { "min_size": 3, "max_size": 6 },
        "minecraft:biome_filter": {
          "any_of": [
            { "test": "has_biome_tag", "operator": "==", "value": "desert" }
          ]
        }
      }
    ]
  }
}