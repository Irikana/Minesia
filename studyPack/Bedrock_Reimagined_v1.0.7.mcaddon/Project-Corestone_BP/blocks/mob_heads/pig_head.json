{
    "format_version": "1.26.0",
	"minecraft:block": {
        "description": {
            "identifier": "5fs_br:pig_head",
            "traits": {
                "minecraft:placement_position": {
                    "enabled_states": [
                        "minecraft:block_face"
                    ]
                }
            },
            "states": {
                "5fs_br:rotation": {
                    "values": {
                        "min": 0,
                        "max": 15
                    }
                }
            }
        },
        "components": {
            "minecraft:collision_box": {
                "origin": [
                    -4,
                    0,
                    -4
                ],
                "size": [
                    8,
                    8,
                    8
                ]
            },
            "minecraft:selection_box": {
                "origin": [
                    -4,
                    0,
                    -4
                ],
                "size": [
                    8,
                    8,
                    8
                ]
            },
            "minecraft:geometry": {
                "identifier": "geometry.pig_head",
                "bone_visibility": {
                    "up_0": "q.block_state('minecraft:block_face') == 'up' && math.mod(q.block_state('5fs_br:rotation'), 4) == 0",
                    "up_22_5": "q.block_state('minecraft:block_face') == 'up' && math.mod(q.block_state('5fs_br:rotation'), 4) == 1",
                    "up_45": "q.block_state('minecraft:block_face') == 'up' && math.mod(q.block_state('5fs_br:rotation'), 4) == 2",
                    "up_67_5": "q.block_state('minecraft:block_face') == 'up' && math.mod(q.block_state('5fs_br:rotation'), 4) == 3",
                    "side": "q.block_state('minecraft:block_face') != 'up'"
                }
            },
            "minecraft:material_instances": {
                "*": {
                    "texture": "pig_head",
                    "ambient_occlusion": false,
                    "face_dimming": false
                }
            },
            "minecraft:destructible_by_mining": {
                "seconds_to_destroy": 1
            },
            "minecraft:destructible_by_explosion": {
                "explosion_resistance": 1
            },
            "minecraft:light_dampening": 0,
            "minecraft:liquid_detection": {
                "detection_rules": [
                    {
                        "can_contain_liquid": true,
                        "liquid_type": "water",
                        "on_liquid_touches": "popped"
                    }
                ]
            },
            "minecraft:placement_filter": {
                "conditions": [
                    {
                        "allowed_faces": [
                            "up",
                            "side"
                        ]
                    }
                ]
            },
            "minecraft:destruction_particles": {
                "texture": "skull"
            },
            "minecraft:precipitation_interactions": {
                "precipitation_behavior": "obstruct_rain"
            },
            "minecraft:connection_rule": {
                "accepts_connections_from": "none"
            },
            "5fs_br:mob_head": {
                "noteblock_sound": "mob.pig.say"
            }
        },
        "permutations": [
            {
                "condition": "q.block_state('5fs_br:rotation') >= 4 || q.block_state('minecraft:block_face') == 'east'",
                "components": {
                    "minecraft:transformation": {
                        "rotation": [
                            0,
                            -90,
                            0
                        ]
                    }
                }
            },
            {
                "condition": "q.block_state('5fs_br:rotation') >= 8 || q.block_state('minecraft:block_face') == 'south' || q.block_state('minecraft:block_face') == 'down'",
                "components": {
                    "minecraft:transformation": {
                        "rotation": [
                            0,
                            180,
                            0
                        ]
                    }
                }
            },
            {
                "condition": "q.block_state('5fs_br:rotation') >= 12 || q.block_state('minecraft:block_face') == 'west'",
                "components": {
                    "minecraft:transformation": {
                        "rotation": [
                            0,
                            90,
                            0
                        ]
                    }
                }
            },
            {
                "condition": "q.block_state('minecraft:block_face') != 'up'",
                "components": {
                    "minecraft:collision_box": {
                        "origin": [
                            -4,
                            4,
                            0
                        ],
                        "size": [
                            8,
                            8,
                            8
                        ]
                    },
                    "minecraft:selection_box": {
                        "origin": [
                            -4,
                            4,
                            0
                        ],
                        "size": [
                            8,
                            8,
                            8
                        ]
                    }
                }
            }
        ]
    }
}