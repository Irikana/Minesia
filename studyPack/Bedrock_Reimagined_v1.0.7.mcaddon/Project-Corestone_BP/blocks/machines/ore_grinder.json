{
	"format_version": "1.26.0",
	"minecraft:block": {
		"description": {
			"identifier": "5fs_br:ore_grinder",
            "menu_category": {
                "category": "items"
            },
			"traits": {
				"minecraft:placement_direction": {
					"enabled_states": [
						"minecraft:cardinal_direction"
					],
					"y_rotation_offset": 180
				}
			},
			"states": {
				"5fs_br:lit": [
					false,
					true
				]
			}
		},
		"components": {
			"5fs_br:ore_grinder": {},
            "minecraft:map_color": "#4E4E4E",
			"minecraft:tick": {
				"looping": true,
				"interval_range": [
					4,
					4
				]
			},
			"minecraft:material_instances": {
				"up": {
					"texture": "ore_grinder_top"
				},
				"down": {
					"texture": "ore_grinder_bottom"
				},
				"north": {
					"texture": "ore_grinder_front"
				},
				"*": {
					"texture": "ore_grinder_side"
				}
			},
			"minecraft:destructible_by_mining": {
				"seconds_to_destroy": 10,
				"item_specific_speeds": [
					{
						"item": {
							"tags": "query.all_tags('minecraft:is_pickaxe') && !query.all_tags('minecraft:wooden_tier')"
						},
						"destroy_speed": 3
					}
				]
			},
			"minecraft:destructible_by_explosion": {
				"explosion_resistance": 6
			},
			"minecraft:geometry": "minecraft:geometry.full_block",
			"tag:furnace": {},
			"tag:5fs_br:stone_tier_destructible": {},
			"tag:minecraft:is_pickaxe_item_destructible": {}
		},
		"permutations": [
			{
				"condition": "q.block_state('minecraft:cardinal_direction') == 'north'",
				"components": {
					"minecraft:transformation": {
						"rotation": [
							0,
							0,
							0
						]
					}
				}
			},
			{
				"condition": "q.block_state('minecraft:cardinal_direction') == 'west'",
				"components": {
					"minecraft:transformation": {
						"rotation": [
							0,
							90,
							0
						]
					}
				}
			},
			{
				"condition": "q.block_state('minecraft:cardinal_direction') == 'east'",
				"components": {
					"minecraft:transformation": {
						"rotation": [
							0,
							-90,
							0
						]
					}
				}
			},
			{
				"condition": "q.block_state('minecraft:cardinal_direction') == 'south'",
				"components": {
					"minecraft:transformation": {
						"rotation": [
							0,
							180,
							0
						]
					}
				}
			},
			{
      "condition": "!q.block_state('5fs_br:lit')", // not powered (default)
      "components": {
        "minecraft:light_emission": 0
      }
    },
    {
      "condition": "q.block_state('5fs_br:lit')", // powered
      "components": {
        "minecraft:light_emission": 3
      }
    }
		]
	}
}
