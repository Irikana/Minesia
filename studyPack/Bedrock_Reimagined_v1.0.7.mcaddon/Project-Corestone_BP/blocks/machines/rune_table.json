{
	"format_version": "1.26.0",
	"minecraft:block": {
		"description": {
			"identifier": "5fs_br:rune_table",
			"menu_category": {
				"category": "items"
			},
			"traits": {
				"minecraft:placement_direction": {
					"enabled_states": [
						"minecraft:cardinal_direction"
					],
					"y_rotation_offset": 180
				}
			}
		},
		"components": {
			"minecraft:map_color": "#800080",
			"minecraft:crafting_table": {
				"crafting_tags": [
					"runetable"
				],
				"table_name": "Rune Table§n§a§i§n"
			},
			"5fs_br:particles": {
				"particles": [
					"5fs_br:magic_letters_particles"
				]
			},
			"minecraft:material_instances": {
