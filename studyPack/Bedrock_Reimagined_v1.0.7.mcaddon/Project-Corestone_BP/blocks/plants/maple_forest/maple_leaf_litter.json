{
	"format_version": "1.26.0",
	"minecraft:block": {
		"description": {
			"identifier": "5fs_br:maple_leaf_litter",
			"traits": {
				"minecraft:placement_direction": {
					"enabled_states": [
						"minecraft:cardinal_direction"
					]
				}
			},
			"states": {
				"5fs_br:growth": [
					0,
					1,
					2,
					3
				]
			}
		},
		"permutations": [
			{
				"condition": "query.block_state('minecraft:cardinal_direction') == 'south'",
				"components": {
					"minecraft:transformation": {
						"rotation": [
							0,
							180,
							0
						]
					}
				}
			},
			{
				"condition": "query.block_state('minecraft:cardinal_direction') == 'east'",
				"components": {
					"minecraft:transformation": {
						"rotation": [
							0,
							-90,
							0
						]
					}
				}
			},
			{
				"condition": "query.block_state('minecraft:cardinal_direction') == 'west'",
				"components": {
					"minecraft:transformation": {
						"rotation": [
							0,
							90,
							0
						]
					}
				}
			},
			{
				"condition": "query.block_state('5fs_br:growth') == 1",
				"components": {
					"minecraft:loot": "loot_tables/blocks/maple_leaf_litter/litter0.json"
				}
			},
			{
				"condition": "query.block_state('5fs_br:growth') == 2",
				"components": {
					"minecraft:loot": "loot_tables/blocks/maple_leaf_litter/litter1.json"
				}
			},
			{
				"condition": "query.block_state('5fs_br:growth') == 3",
				"components": {
					"minecraft:loot": "loot_tables/blocks/maple_leaf_litter/litter2.json"
				}
			}
		],
		"components": {
			"minecraft:geometry": {
				"identifier": "geometry.maple_leaf_litter",
				"bone_visibility": {
					"leaf0": "query.block_state('5fs_br:growth') >= 0",
					"leaf1": "query.block_state('5fs_br:growth') >= 1",
					"leaf2": "query.block_state('5fs_br:growth') >= 2",
					"leaf3": "query.block_state('5fs_br:growth') >= 3"
				}
			},
			"minecraft:flammable": true,
			"minecraft:light_dampening": 0,
			"minecraft:collision_box": false,
			"minecraft:selection_box": {
				"origin": [
					-8,
					0,
					-8
				],
				"size": [
					16,
					1,
					16
				]
			},
			"5fs_br:multi_patch_block": {
				"place_sound": "block.leaf_litter.place",
				"max": 3
			},
			"minecraft:material_instances": {
				"*": {
					"texture": "maple_leaf_litter",
					"render_method": "alpha_test",
					"ambient_occlusion": false,
					"face_dimming": false
				}
			},
			"minecraft:map_color": "#D7431B",
			"minecraft:liquid_detection": {
				"detection_rules": [
					{
						"on_liquid_touches": "popped"
					}
				]
			},
			"minecraft:destruction_particles": {
				"texture": "maple_leaf_litter"
			},
			"minecraft:replaceable": {},
            "minecraft:precipitation_interactions": {
                "precipitation_behavior": "none"
            },
            "minecraft:connection_rule": {
                "accepts_connections_from": "none"
            },
			"tag:5fs_br:up": {}
		}
	}
}