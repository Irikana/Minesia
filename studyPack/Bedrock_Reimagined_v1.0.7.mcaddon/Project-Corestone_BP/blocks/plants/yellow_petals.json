{
	"format_version": "1.26.0",
	"minecraft:block": {
		"description": {
			"identifier": "5fs_br:yellow_petals",
			"traits": {
				"minecraft:placement_direction": {
					"enabled_states": [
						"minecraft:cardinal_direction"
					]
				}
			},
			"states": {
				"5fs_br:growth": [
					0,
					1,
					2,
					3
				]
			}
		},
		"permutations": [
			{
				"condition": "query.block_state('minecraft:cardinal_direction') == 'south'",
				"components": {
					"minecraft:transformation": {
						"rotation": [
							0,
							180,
							0
						]
					}
				}
			},
			{
				"condition": "query.block_state('minecraft:cardinal_direction') == 'east'",
				"components": {
					"minecraft:transformation": {
						"rotation": [
							0,
							-90,
							0
						]
					}
				}
			},
			{
				"condition": "query.block_state('minecraft:cardinal_direction') == 'west'",
				"components": {
					"minecraft:transformation": {
						"rotation": [
							0,
							90,
							0
						]
					}
				}
			},
			{
				"condition": "query.block_state('5fs_br:growth') == 1",
				"components": {
					"minecraft:loot": "loot_tables/blocks/petals/yellow_petals/yellow_petals0.json"
				}
			},
			{
				"condition": "query.block_state('5fs_br:growth') == 2",
				"components": {
					"minecraft:loot": "loot_tables/blocks/petals/yellow_petals/yellow_petals1.json"
				}
			},
			{
				"condition": "query.block_state('5fs_br:growth') == 3",
				"components": {
					"minecraft:loot": "loot_tables/blocks/petals/yellow_petals/yellow_petals2.json"
				}
			}
		],
		"components": {
			"minecraft:geometry": {
				"identifier": "geometry.yellow_petals",
				"bone_visibility": {
					"petals0": "query.block_state('5fs_br:growth') >= 0",
					"petals1": "query.block_state('5fs_br:growth') >= 1",
					"petals2": "query.block_state('5fs_br:growth') >= 2",
					"petals3": "query.block_state('5fs_br:growth') >= 3"
				}
			},
			"minecraft:flammable": true,
			"minecraft:light_dampening": 0,
			"minecraft:placement_filter": {
				"conditions": [
					{
						"block_filter": [
							{
								"tags": "query.any_tag('dirt')"
							},
							"minecraft:grass_block",
							"minecraft:dirt",
							"minecraft:moss_block",
							"minecraft:mycelium",
							"minecraft:coarse_dirt",
							"minecraft:dirt_with_roots",
							"minecraft:mud",
							"minecraft:muddy_mangrove_roots",
							"minecraft:pale_moss_block"
						],
						"allowed_faces": [
							"up"
						]
					}
				]
			},
			"minecraft:collision_box": false,
			"minecraft:selection_box": {
				"origin": [
					-8,
					0,
					-8
				],
				"size": [
					16,
					3,
					16
				]
			},
			"minecraft:material_instances": {
				"*": {
					"texture": "yellow_petals",
					"render_method": "alpha_test",
					"ambient_occlusion": false,
					"face_dimming": false
				},
				"petals": {
					"texture": "yellow_petals",
					"render_method": "alpha_test",
					"ambient_occlusion": false,
					"face_dimming": false
				},
				"stem": {
					"texture": "petals_stem",
					"render_method": "alpha_test",
					"ambient_occlusion": true,
					"face_dimming": false,
					"tint_method": "grass"
				}
			},
			"minecraft:liquid_detection": {
				"detection_rules": [
					{
						"on_liquid_touches": "popped"
					}
				]
			},
			"minecraft:destruction_particles": {
				"texture": "yellow_petals"
			},
            "minecraft:movable": {
                "movement_type": "popped",
                "sticky": "none"
            },
            "5fs_br:multi_patch_block": {
                "place_sound": "place.pink_petals",
				"max": 3
            },
            "minecraft:connection_rule": {
                "accepts_connections_from": "none"
            },
	        "tag:plant": {}
		}
	}
}