{"format_version":"1.19.0","animation_controllers":{"controller.animation.allay.general":{"initial_state":"idle","states":{"idle":{"animations":[{"idle":"q.is_alive"}],"transitions":[{"walking":"q.ground_speed > 1.0"}],"blend_transition":0.2,"blend_via_shortest_path":true},"walking":{"animations":[{"flying":"q.modified_move_speed *1.2"}],"transitions":[{"idle":"q.ground_speed < 0.5"}],"blend_transition":0.2,"blend_via_shortest_path":true}}},"controller.animation.allay.throwing_item":{"initial_state":"no_item","states":{"no_item":{"transitions":[{"holding_item":"v.is_holding_right"}]},"holding_item":{"animations":["hold_item_flying"],"transitions":[{"throw_item":"!v.is_holding_right"}]},"throw_item":{"animations":["throwing_item"],"transitions":[{"no_item":"q.any_animation_finished"}]}}},"controller.animation.allay.death":{"states":{"default":{"transitions":[{"death":"!q.is_alive"}]},"death":{"animations":["death","death_rotation"]}}}}}