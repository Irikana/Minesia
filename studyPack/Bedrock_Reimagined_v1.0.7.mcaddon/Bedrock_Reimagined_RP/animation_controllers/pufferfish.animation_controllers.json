{"format_version":"1.19.0","animation_controllers":{"controller.animation.pufferfish.general":{"initial_state":"flopping","states":{"flopping":{"animations":["flop"],"transitions":[{"swimming":"query.is_in_water || query.is_levitating"}]},"swimming":{"animations":[{"swimming":"q.modified_move_speed *3"}],"transitions":[{"flopping":"!query.is_in_water && !query.is_levitating"}]}}},"controller.animation.pufferfish.inflate":{"states":{"default":{"transitions":[{"mid-inflate_grow":"query.variant == 2"},{"default-mid_grow":"query.variant == 1"},{"death":"!q.is_alive"}]},"default-mid_grow":{"animations":["inflate"],"transitions":[{"mid_flate":"q.any_animation_finished"},{"death":"!q.is_alive"}]},"mid-default_shrink":{"animations":["shrink_flate"],"transitions":[{"default":"q.any_animation_finished"},{"death":"!q.is_alive"}]},"mid_flate":{"transitions":[{"mid-default_shrink":"query.variant == 0"},{"mid-inflate_grow":"query.variant == 2"},{"death":"!q.is_alive"}]},"mid-inflate_grow":{"animations":["inflate"],"transitions":[{"inflate":"q.any_animation_finished"},{"death":"!q.is_alive"}]},"inflate-mid_shrink":{"animations":["shrink_flate"],"transitions":[{"mid_flate":"q.any_animation_finished"},{"death":"!q.is_alive"}]},"inflate":{"transitions":[{"inflate-mid_shrink":"query.variant == 1"},{"default":"query.variant == 0"},{"death":"!q.is_alive"}]},"death":{"animations":["death","death_rotation"]}}}}}