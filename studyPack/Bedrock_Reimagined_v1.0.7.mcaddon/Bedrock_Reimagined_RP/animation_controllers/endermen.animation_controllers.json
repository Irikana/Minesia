{"format_version":"1.10.0","animation_controllers":{"controller.animation.enderman.base_pose":{"initial_state":"default","states":{"default":{"animations":["base_pose","arms_legs"]}}},"controller.animation.enderman.scary_face":{"states":{"default":{"transitions":[{"begin_scary":"query.is_angry"}]},"scary":{"animations":["angry_mouth"],"transitions":[{"end_scary":"!query.is_angry"}]},"begin_scary":{"animations":["enraged"],"transitions":[{"scary":"q.any_animation_finished"}]},"end_scary":{"animations":["calm"],"transitions":[{"default":"q.any_animation_finished"}],"blend_transition":0.2,"blend_via_shortest_path":true}}},"controller.animation.enderman.carrying_new":{"states":{"carry":{"animations":["carrying_new"],"transitions":[{"default":"!query.is_carrying_block"}]},"default":{"transitions":[{"carry":"query.is_carrying_block"}]}}},"controller.animation.enderman.general":{"states":{"default":{"animations":["idle",{"walking":"q.modified_move_speed"}],"transitions":[{"running":"q.has_target"},{"death":"!q.is_alive"},{"attack":"variable.attack_time>0.0"}],"blend_transition":0.2,"blend_via_shortest_path":true},"running":{"animations":["idle",{"run":"q.modified_move_speed"}],"transitions":[{"default":"!q.has_target"},{"death":"!q.is_alive"},{"attack":"variable.attack_time>0.0"}],"blend_transition":0.2,"blend_via_shortest_path":true},"attack":{"animations":["attack"],"transitions":[{"default":"q.any_animation_finished && !q.has_target"},{"running":"q.any_animation_finished && q.has_target"},{"death":"!q.is_alive"}],"blend_transition":0.2,"blend_via_shortest_path":true},"death":{"animations":["death","death_rotation"]}}}}}