{"format_version":"1.19.0","animation_controllers":{"controller.animation.llama.shoot":{"states":{"default":{"transitions":[{"charging":"variable.ischarging&&q.has_target"}]},"charging":{"transitions":[{"shoot":"!q.is_charging"},{"default":"!variable.ischarging&&!q.has_target"}]},"shoot":{"animations":["shoot"],"transitions":[{"default":"q.any_animation_finished"}]}}},"controller.animation.llama.general":{"initial_state":"idle","states":{"idle":{"animations":["idle",{"walk":"q.modified_move_speed *1.2"}],"transitions":[{"walking":"q.ground_speed > 2.5"},{"death":"!q.is_alive"},{"ready_spit":"q.is_charged && q.facing_target_to_range_attack"}],"blend_transition":0.2,"blend_via_shortest_path":true},"walking":{"animations":[{"running":"q.modified_move_speed"}],"transitions":[{"idle":"q.ground_speed < 0.5"},{"death":"!q.is_alive"}],"blend_transition":0.2,"blend_via_shortest_path":true},"ready_spit":{"animations":["timer"],"transitions":[{"spitting":"!q.is_charged && q.facing_target_to_range_attack"},{"death":"!q.is_alive"},{"idle":"q.any_animation_finished"}],"blend_transition":0.2,"blend_via_shortest_path":true},"spitting":{"animations":["shoot"],"transitions":[{"death":"!q.is_alive"},{"idle":"q.any_animation_finished"}],"blend_transition":0.2,"blend_via_shortest_path":true},"death":{"animations":["death","death_rotation"],"blend_transition":0.2,"blend_via_shortest_path":true}}}}}