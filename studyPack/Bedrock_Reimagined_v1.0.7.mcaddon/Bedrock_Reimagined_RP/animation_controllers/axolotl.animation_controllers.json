{"format_version":"1.19.0","animation_controllers":{"controller.animation.axolotl.general":{"states":{"default":{"animations":[{"idle":"q.is_alive && !q.is_playing_dead"}],"transitions":[{"walking":"q.ground_speed > 0.3 && !q.is_in_contact_with_water"},{"swimming":"q.ground_speed > 0.3 && q.is_in_contact_with_water"},{"attacking":"variable.attack_time>0.0"},{"playing_dead":"q.is_playing_dead"}],"blend_transition":0.2,"blend_via_shortest_path":true},"walking":{"animations":["walking"],"transitions":[{"swimming":"q.is_in_contact_with_water"},{"default":"q.ground_speed < 0.05"},{"attacking":"variable.attack_time>0.0"},{"playing_dead":"q.is_playing_dead"}],"blend_transition":0.2,"blend_via_shortest_path":true},"swimming":{"animations":[{"swimming":"q.modified_move_speed"},{"swim_angle":"q.is_alive && variable.moving && q.is_in_contact_with_water"}],"transitions":[{"default":"q.ground_speed < 0.05"},{"walking":"!q.is_in_contact_with_water"},{"attacking":"variable.attack_time>0.0"},{"playing_dead":"q.is_playing_dead"}],"blend_transition":0.2,"blend_via_shortest_path":true},"attacking":{"animations":["attacking"],"transitions":[{"default":"q.any_animation_finished"}],"blend_transition":0.1,"blend_via_shortest_path":true},"playing_dead":{"animations":[{"play_dead":"q.is_alive"}],"transitions":[{"default":"!q.is_playing_dead"}],"blend_transition":0.2}}},"controller.animation.axolotl.death":{"states":{"default":{"transitions":[{"death":"!q.is_alive"}]},"death":{"animations":["death_rotation","death"]}}}}}