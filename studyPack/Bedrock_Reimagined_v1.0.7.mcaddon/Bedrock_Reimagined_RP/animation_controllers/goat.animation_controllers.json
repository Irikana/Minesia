{"format_version":"1.19.0","animation_controllers":{"controller.animation.goat.general":{"states":{"default":{"animations":["idle","timer"],"transitions":[{"walking":"q.is_moving && !q.has_target"},{"running":"q.is_moving && q.has_target"},{"attacking":"variable.attack_time>0.0"},{"funny_idle":"q.any_animation_finished"},{"death":"!q.is_alive"},{"jumping":"!q.is_on_ground"}],"blend_transition":0.4,"blend_via_shortest_path":true},"walking":{"animations":["walking"],"transitions":[{"default":"!q.is_moving"},{"running":"q.has_target"},{"attacking":"variable.attack_time>0.0"},{"death":"!q.is_alive"},{"jumping":"!q.is_on_ground"}],"blend_transition":0.2,"blend_via_shortest_path":true},"running":{"animations":[{"running":"q.modified_move_speed"}],"transitions":[{"default":"!q.is_moving"},{"walking":"!q.has_target"},{"attacking":"variable.attack_time>0.0"},{"death":"!q.is_alive"},{"jumping":"!q.is_on_ground"}],"blend_transition":0.2,"blend_via_shortest_path":true},"attacking":{"animations":["attacking"],"transitions":[{"default":"q.any_animation_finished"},{"death":"!q.is_alive"}],"blend_transition":0.2,"blend_via_shortest_path":true},"funny_idle":{"animations":["funny_idle"],"transitions":[{"default":"q.any_animation_finished"},{"death":"!q.is_alive"},{"walking":"q.is_moving"},{"jumping":"!q.is_on_ground"}],"blend_transition":0.2,"blend_via_shortest_path":true},"jumping":{"animations":["jumping"],"transitions":[{"death":"!q.is_alive"},{"default":"q.is_on_ground || q.is_in_water"}],"blend_transition":0.2,"blend_via_shortest_path":true},"death":{"animations":["death","death_rotation"]}}}}}