{"format_version":"1.19.0","animation_controllers":{"controller.animation.copper_golem.idle":{"initial_state":"selector","states":{"selector":{"transitions":[{"default":"v.oxidation == 'unoxidized' || v.oxidation == 'exposed'"},{"weathered":"v.oxidation == 'weathered'"},{"default":"v.oxidation == 'oxidized'"}]},"default":{"animations":["spin"],"transitions":[{"selector":"query.all_animations_finished"}]},"weathered":{"animations":["spin_weathered"],"transitions":[{"selector":"query.all_animations_finished"}]},"oxidized":{"animations":["spin_oxidized"],"transitions":[{"selector":"query.all_animations_finished"}]}}},"controller.animation.copper_golem.walk":{"states":{"default":{"animations":[{"walking":"q.modified_move_speed"},"inactive"],"transitions":[{"holding_item":"v.is_holding_right"}],"blend_transition":0.2},"holding_item":{"animations":[{"walking_holding":"q.modified_move_speed"},"hold_item"],"transitions":[{"default":"!v.is_holding_right"}],"blend_transition":0.2}}},"controller.animation.copper_golem.chest_interaction":{"initial_state":"none","states":{"none":{"transitions":[{"put_item":"v.chest_interaction == 'put'"},{"put_item_fail":"v.chest_interaction == 'put_fail'"},{"take_item":"v.chest_interaction == 'take'"},{"take_item_fail":"v.chest_interaction == 'take_fail'"}],"blend_transition":0.2},"put_item":{"animations":["place_item"],"transitions":[{"none":"query.all_animations_finished"}]},"put_item_fail":{"animations":["failing_item"],"transitions":[{"none":"query.all_animations_finished"}]},"take_item":{"animations":["taking_item"],"transitions":[{"none":"query.all_animations_finished"}]},"take_item_fail":{"animations":["item_take_fail"],"transitions":[{"none":"query.all_animations_finished"}]}}},"controller.animation.copper_golem.death_controller":{"states":{"default":{"transitions":[{"dead":"!q.is_alive"}]},"dead":{"animations":["death","death_rotation"]}}}}}