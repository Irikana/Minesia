{"format_version":"1.10.0","animation_controllers":{"controller.animation.zombie.general":{"initial_state":"idle","states":{"running":{"animations":[{"running":"q.modified_move_speed *1.2"},"running_arms"],"transitions":[{"riding":"q.is_riding"},{"idle":"!q.is_moving || !q.has_target"},{"attack":"variable.attack_time>0.0"}],"blend_transition":0.2,"blend_via_shortest_path":true},"idle":{"animations":[{"idle":"q.is_alive"},"timer",{"zombie_look_at_target":"q.is_alive"},{"walking":"q.modified_move_speed"}],"transitions":[{"attack":"variable.attack_time>0.0"},{"riding":"q.is_riding"},{"bored":"q.any_animation_finished && !q.has_rider && !q.is_moving"}],"blend_transition":0.4,"blend_via_shortest_path":true},"attack":{"animations":["attack",{"attack_walking":"q.modified_move_speed *1.2"}],"transitions":[{"idle":"q.any_animation_finished && !q.is_moving"},{"riding":"q.is_riding"},{"running":"q.any_animation_finished && q.is_moving"}],"blend_transition":0.2,"blend_via_shortest_path":true},"riding":{"animations":["riding.arms","riding.legs","riding.body"],"transitions":[{"idle":"!q.is_riding"},{"riding_attack":"variable.attack_time>0.0"}],"blend_transition":0.2,"blend_via_shortest_path":true},"bored":{"animations":[{"bored":"q.is_alive"}],"transitions":[{"idle":"q.any_animation_finished || q.is_moving"},{"riding":"q.is_riding"},{"attack":"variable.attack_time>0.0"}],"blend_transition":0.2,"blend_via_shortest_path":true},"riding_attack":{"animations":["riding_legs","attack"],"transitions":[{"riding":"q.any_animation_finished"}],"blend_transition":0.2,"blend_via_shortest_path":true}}},"controller.animation.zombie.death":{"states":{"default":{"transitions":[{"death":"!q.is_alive"}],"blend_transition":0.2,"blend_via_shortest_path":true},"death":{"animations":["death","death_rotation"]}}},"controller.animation.zombie.new":{"initial_state":"idle","states":{"idle":{"transitions":[{"walking":"q.ground_speed > 1.0"}],"blend_transition":0.2},"walking":{"transitions":[{"idle":"q.ground