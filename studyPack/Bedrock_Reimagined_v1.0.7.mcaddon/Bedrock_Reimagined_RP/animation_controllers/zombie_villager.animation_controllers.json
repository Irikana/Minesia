{"format_version":"1.19.0","animation_controllers":{"controller.animation.zombie.new":{"initial_state":"idle","states":{"idle":{"transitions":[{"walking":"q.ground_speed > 1.0"}],"blend_transition":0.2},"walking":{"transitions":[{"idle":"q.ground_speed < 0.5"}],"blend_transition":0.2}}},"controller.animation.zombie_villager.general":{"initial_state":"idle","states":{"walking":{"animations":[{"walking":"q.modified_move_speed *1.2"},{"idle":"q.is_alive"}],"transitions":[{"running":"q.has_target"},{"riding":"q.is_riding"},{"idle":"q.ground_speed < 0.5"},{"attack":"variable.attack_time>0.0"}],"blend_transition":0.2,"blend_via_shortest_path":true},"running":{"animations":[{"running":"q.modified_move_speed"},"running_arms"],"transitions":[{"walking":"!q.has_target"},{"riding":"q.is_riding"},{"idle":"!q.is_moving"},{"attack":"variable.attack_time>0.0"}],"blend_transition":0.2,"blend_via_shortest_path":true},"idle":{"animations":[{"idle":"q.is_alive"},"timer",{"zombie_look_at_target":"q.is_alive"}],"transitions":[{"attack":"variable.attack_time>0.0"},{"walking":"q.ground_speed > 1.0"},{"riding":"q.is_riding"},{"bored":"q.any_animation_finished"}],"blend_transition":0.4,"blend_via_shortest_path":true},"attack":{"animations":["attack",{"attack_walking":"q.modified_move_speed *1.2"}],"transitions":[{"idle":"q.any_animation_finished && !q.is_moving"},{"riding":"q.is_riding"},{"running":"q.any_animation_finished && q.is_moving"}],"blend_transition":0.2,"blend_via_shortest_path":true},"riding":{"animations":["riding.arms","riding.legs","riding.body"],"transitions":[{"idle":"!q.is_riding"}],"blend_transition":0.2,"blend_via_shortest_path":true},"bored":{"animations":[{"bored":"q.is_alive"}],"transitions":[{"walking":"q.ground_speed > 1.0"},{"idle":"q.any_animation_finished"},{"riding":"q.is_riding"},{"attack":"variable.attack_time>0.0"}],"blend_transition":0.2,"blend_via_shortest_path":true}}},"controller.animation.zombie_villager.death":{"states":{"default":{"transitions":[{"deat