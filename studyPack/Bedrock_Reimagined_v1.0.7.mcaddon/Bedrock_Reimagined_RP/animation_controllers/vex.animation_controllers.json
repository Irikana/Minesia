{"format_version":"1.19.0","animation_controllers":{"controller.animation.vex.idle":{"states":{"default":{"animations":[{"idle":"q.is_alive *1.2"}],"transitions":[{"move":"q.ground_speed > 1.0"},{"attack":"q.is_charging"}],"blend_transition":0.2,"blend_via_shortest_path":true},"move":{"animations":[{"flying":"q.modified_move_speed"}],"transitions":[{"default":"q.ground_speed < 0.5"},{"attack":"q.is_charging"}],"blend_transition":0.2,"blend_via_shortest_path":true},"attack":{"animations":["deploy_2"],"transitions":[{"one_last_attack":"!q.is_charging"}],"blend_transition":0.2,"blend_via_shortest_path":true},"one_last_attack":{"animations":["attacking_2"],"transitions":[{"flying_back":"q.any_animation_finished"}],"blend_transition":0.2,"blend_via_shortest_path":true},"flying_back":{"animations":["return_flight"],"transitions":[{"default":"q.any_animation_finished && q.ground_speed < 0.5"},{"attack":"q.is_charging"},{"move":"q.any_animation_finished && q.ground_speed > 1.0"}],"blend_transition":0.4,"blend_via_shortest_path":true}}},"controller.animation.vex.death":{"states":{"default":{"transitions":[{"death":"!q.is_alive"}]},"death":{"animations":["dying","death_rotation"]}}}}}