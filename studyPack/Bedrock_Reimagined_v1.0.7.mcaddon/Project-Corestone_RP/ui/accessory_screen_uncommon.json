{
    "namespace": "accessory_screen_uncommon",
    "accessories_top": {
        "type": "collection_panel",
        "anchor_from": "center",
        "anchor_to": "center",
        "size": [
            "100%",
            "25%"
        ],
        "offset": [
            "-13%",
            -10
        ],
        "collection_name": "container_items",
        "$item_collection_name": "container_items",
        "controls": [
            {
                "ring_1@common.container_item": {
                    "anchor_from": "top_left",
                    "anchor_to": "top_left",
                    "offset": [
                        60,
                        -52
                    ],
                    "$cell_overlay_ref": "accessory_common.slot_ring",
                    "collection_index": 0
                }
            },
            {
                "belt@common.container_item": {
                    "anchor_from": "top_left",
                    "anchor_to": "top_left",
                    "offset": [
                        144.5,
                        -52
                    ],
                    "$cell_overlay_ref": "accessory_common.slot_belt",
                    "collection_index": 1
                }
            },
            {
                "hat@accessory_common.accessory_slot_locked": {
                    "anchor_from": "top_left",
                    "anchor_to": "top_left",
                    "offset": [
                        60,
                        -26
                    ],
                    "$cell_overlay_ref": "accessory_common.slot_hat",
                    "collection_index": 2
                }
            },
            {
                "ring_2@accessory_common.accessory_slot_locked": {
                    "anchor_from": "top_left",
                    "anchor_to": "top_left",
                    "offset": [
                        144.5,
                        -26
                    ],
                    "$cell_overlay_ref": "accessory_common.slot_ring",
                    "collection_index": 3
                }
            },
            {
                "talisman_1@accessory_common.accessory_slot_locked": {
                    "anchor_from": "top_left",
                    "anchor_to": "top_left",
                    "offset": [
                        60,
                        0
                    ],
                    "$cell_overlay_ref": "accessory_common.slot_talisman",
                    "collection_index": 4
                }
            },
            {
                "talisman_2@accessory_common.accessory_slot_locked": {
                    "anchor_from": "top_left",
                    "anchor_to": "top_left",
                    "offset": [
                        144.5,
                        0
                    ],
                    "$cell_overlay_ref": "accessory_common.slot_talisman",
                    "collection_index": 5
                }
            }
        ]
    },
    "accessories_panel": {
        "type": "panel",
        "$background_image_control_name": "bg",
        "$background_images": "accessory_common.accessories_item_bg",
        "$chest_image": "textures/gui/inventory/acc_bag/Corestone_UI_Accessory_Bags_2",
        "$size": [
            "150%",
            "150%"
        ],
        "$offset": [
            "5%",
            "10%"
        ],
        "$title_text_color": [
            1,
            1,
            1
        ],
        "controls": [
            {
                "container_gamepad_helpers@common.container_gamepad_helpers": {}
            },
            {
                "flying_item_renderer@common.flying_item_renderer": {
                    "layer": 14
                }
            },
            {
                "selected_item_details_factory@common.selected_item_details_factory": {}
            },
            {
                "item_lock_notification_factory@common.item_lock_notification_factory": {}
            },
            {
                "root_screen_panel@common.root_panel": {
                    "layer": 1,
                    "controls": [
                        {
                            "image_background": {
                                "type": "image",
                                "texture": "$chest_image",
                                "size": "$size",
                                "offset": "$offset"
                            }
                        },
                        {
                            "chest_panel": {
                                "type": "panel",
                                "layer": 5,
                                "controls": [
                                    {
                                        "player_renderer_panel": {
                                            "type": "panel",
                                            "size": [
                                                30,
                                                30
                                            ],
                                            "offset": [
                                                0,
                                                -60
                                            ],
                                            "controls": [
                                                {
                                                    "player_renderer": {
                                                        "type": "custom",
                                                        "renderer": "live_player_renderer",
                                                        "property_bag": {
                                                            "#look_at_cursor": true
                                                        },
                                                        "animation_reset_name": "screen_animation_reset",
                                                        "anims": [
                                                            "@common.screen_exit_size_animation_push",
                                                            "@common.screen_exit_size_animation_pop",
                                                            "@common.screen_entrance_size_animation_push",
                                                            "@common.screen_entrance_size_animation_pop"
                                                        ],
                                                        "layer": 8,
                                                        "anchor_from": "center",
                                                        "anchor_to": "center"
                                                    }
                                                }
                                            ]
                                        }
                                    },
                                    {
                                        "accessories_top@accessory_screen_uncommon.accessories_top": {}
                                    },
                                    {
                                        "inventory_panel_bottom_half_with_label@common.inventory_panel_bottom_half_with_label": {}
                                    },
                                    {
                                        "hotbar_grid@common.hotbar_grid_template": {}
                                    },
                                    {
                                        "inventory_take_progress_icon_button@common.inventory_take_progress_icon_button": {}
                                    }
                                ]
                            }
                        },
                        {
                            "inventory_selected_icon_button@common.inventory_selected_icon_button": {}
                        },
                        {
                            "gamepad_cursor@common.gamepad_cursor_button": {}
                        },
                        {
                            "close@common.close_button": {
                                "layer": 4,
                                "offset": [
                                    0,
                                    0
                                ]
                            }
                        }
                    ]
                }
            }
        ]
    }
}