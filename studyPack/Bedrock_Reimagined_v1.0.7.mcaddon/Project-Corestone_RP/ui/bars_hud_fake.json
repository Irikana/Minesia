{
    "namespace": "bars_commons_fake",
    "bar_hunger": {
        "type": "panel",
        "anchor_from": "top_left",
        "anchor_to": "top_left",
        "size": ["100%","100%"],
        "layer": 20,
        "$image_texture_white":"textures/gui/hud/status_bar_hunger_full_white",
        "controls": [
            {
                "hungry_bar": {
                    "$image_texture": "textures/gui/hud/status_bar_hunger_full",
                    "anchor_from": "top_left",
                    "anchor_to": "top_left",
                    "$source_control_name": "hunger_bar_control",
                    "$selection": 1,
                    "type": "panel",
                    "size": [
                        "100%",
                        "100%"
                    ],
                    "controls": [
                        {
                            "container_image": {
                                "type": "panel",
                                // "clips_children": false,
                                "anchor_from": "center",
                                "anchor_to": "center",
                                "size": [
                                    "100%",
                                    "100%"
                                ],
                                "$multiplier": 0.01,
                                "$min": 1.0,
                                "$direction|default": 0,
                                "$direction_1|default": "left_middle",
                                "$direction_2|default": "left_middle",
                                "$can_change_texture|default": false,
                                "variables": [
                                    {
                                        "requires": "($direction = 1)",
                                        "$direction_1": "right_middle",
                                        "$direction_2": "right_middle"
                                    }
                                ],
                                "controls": [
                                    {
                                        "image_bar": {
                                            "type": "image",
                                            "texture": "$image_texture",
                                            "$image_texture|default": "textures/gui/hud/status_bar_hunger_full",
                                            "size": [
                                                "100%",
                                                "100%"
                                            ],
                                            "anchor_from": "$direction_1",
                                            "anchor_to": "$direction_2",
                                            // "size": "$size_anim",
                                            "layer": 30
                                        }
                                    }
                                ]
                            }
                        }
                    ]
                }
            }
        ]
    },
