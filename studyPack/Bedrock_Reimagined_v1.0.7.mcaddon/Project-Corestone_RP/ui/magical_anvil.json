{
  "namespace": "chest",

  "magical_anvil_label": {
    "type": "label",
    "offset": [4, -17],
    "anchor_from": "top_middle",
    "anchor_to": "top_middle",
    "text": "$container_title",
    "size": ["70%", "default"],
    "color": "$title_text_color",
    "layer": 2
  },

  "chest_grid_item@common.container_item": {
    "$item_collection_name": "container_items"
  },

  "slot_1": {
    "type": "stack_panel",
    "anchor_from": "top_middle",
    "anchor_to": "top_middle",
    "orientation": "horizontal",
    "collection_name": "container_items",
    "controls": [
      { "test@chest.chest_grid_item": { "collection_index": 0 } }
    ]
  }, //
  "slot_2": {
    "type": "stack_panel",
    "anchor_from": "top_middle",
    "anchor_to": "top_middle",
    "orientation": "horizontal",
    "collection_name": "container_items",
    "controls": [
      { "test@chest.chest_grid_item": { "collection_index": 1 } }
    ]
  },
  "slot_3": {
    "type": "stack_panel",
    "anchor_from": "top_middle",
    "anchor_to": "top_middle",
    "orientation": "horizontal",
    "collection_name": "container_items",
    "controls": [
      { "test@chest.chest_grid_item": { "collection_index": 2 } }
    ]
  },


  "magical_anvil_panel_top_half": {
    "type": "panel",
    "size": ["100%", "25%"],
    "anchor_to": "top_middle",
    "anchor_from": "top_middle",
    "offset": [0, 27],
    "controls": [
      { "magical_anvil_label@chest.magical_anvil_label": {} },
      { "slot_1@chest.slot_1": { "offset": [-37, 23] } },
      { "slot_2@chest.slot_2": { "offset": [-2, 23] } },
      { "slot_3@chest.slot_3": { "offset": [50, 23] } }
    ]
  },

  "magical_anvil_panel": {
    "type": "panel",
    "$background_image_control_name": "bg",
    "$background_images": "furnace.empty",
    "$chest_image": "textures/gui/inventory/magic_anvil_image",
    "$size": [
        "150%",
        "150%"
    ],
    "$offset": [
        "5%",
        "10%"
    ],
    "$title_text_color": [
      1,
      1,
      1
    ],
    "controls": [
      { "container_gamepad_helpers@common.container_gamepad_helpers": {} },
      { "flying_item_renderer@common.flying_item_renderer": { "layer": 14 } },
      { "selected_item_details_factory@common.selected_item_details_factory": {} },
      { "item_lock_notification_factory@common.item_lock_notification_factory": {} },
      {
        "root_panel@common.root_panel": {
          "layer": 1,
          "controls": [
            // { "common_panel@common.common_panel": {} },
            {
                "close@common.close_button": {
                    "layer": 4,
                    "offset": [
                        0,
                        0
                    ]
                }
            },
            {
              "image_background": {
                "type": "image",
                "size": "$size",
                "offset": "$offset",
                "texture": "$chest_image"
              }
            },
            {
              "chest_panel": {
                "type": "panel",
                "layer": 5,
                "controls": [
                  { "magical_anvil_panel_top_half@chest.magical_anvil_panel_top_half": {} },
                  { "inventory_panel_bottom_half_with_label@common.inventory_panel_bottom_half_with_label": {} },
                  { "hotbar_grid@common.hotbar_grid_template": {} },
                  { "inventory_take_progress_icon_button@common.inventory_take_progress_icon_button": {} }
                ]
              }
            },
            { "inventory_selected_icon_button@common.inventory_selected_icon_button": {} },
            { "gamepad_cursor@common.gamepad_cursor_button": {} }
          ]
        }
      }
    ]
  }
}