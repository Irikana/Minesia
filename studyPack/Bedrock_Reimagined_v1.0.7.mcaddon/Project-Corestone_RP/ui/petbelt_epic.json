                    ],
                    "collection_index": 1
                }
            },
            {
                "item3@common.container_item": {
                    "anchor_from": "top_left",
                    "anchor_to": "top_left",
                    "offset": [
                        78,
                        -18
                    ],
                    "collection_index": 2
                }
            },
            {
                "item4@common.container_item": {
                    "anchor_from": "top_left",
                    "anchor_to": "top_left",
                    "offset": [
                        114,
                        -18
                    ],
                    "collection_index": 3
                }
            }
        ]
    },
    "petbelt_panel": {
        "type": "panel",
