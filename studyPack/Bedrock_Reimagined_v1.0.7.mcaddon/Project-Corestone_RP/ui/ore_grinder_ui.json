{
  "namespace": "chest",

  "ore_grinder_background": {
    "type": "image",
    "texture": "textures/gui/ore_grinder_ui",
    "size": [256, 270],
    "anchor_from": "top_middle",
    "anchor_to": "top_middle",
    "offset": [41, -43],
    "layer": 2
  },

  "ore_grinder_label": {
    "type": "label",
    "offset": [32, -32],
    "anchor_from": "top_middle",
    "anchor_to": "top_middle",
    "text": "Ore Grinder",
    "size": ["70%", "default"],
    "color": "$title_text_color",
    "layer": 3
  },

  "ore_grinder_grid_item@common.container_item": {
    "$item_collection_name": "container_items"
  },

  "slot_fuel": {
    "type": "stack_panel",
    "anchor_from": "middle_left",
    "anchor_to": "middle_left",
    "orientation": "horizontal",
    "collection_name": "container_items",
    "controls": [
      { "fuel@chest.ore_grinder_grid_item": { "collection_index": 0 } }
    ]
  },

  "slot_in_1": { "type": "stack_panel", "anchor_from": "top_middle", "anchor_to": "top_middle", "orientation": "horizontal", "collection_name": "container_items", "controls": [ { "in1@chest.ore_grinder_grid_item": { "collection_index": 1 } } ] },
  "slot_in_2": { "type": "stack_panel", "anchor_from": "top_middle", "anchor_to": "top_middle", "orientation": "horizontal", "collection_name": "container_items", "controls": [ { "in2@chest.ore_grinder_grid_item": { "collection_index": 2 } } ] },
  "slot_in_3": { "type": "stack_panel", "anchor_from": "top_middle", "anchor_to": "top_middle", "orientation": "horizontal", "collection_name": "container_items", "controls": [ { "in3@chest.ore_grinder_grid_item": { "collection_index": 3 } } ] },
  "slot_in_4": { "type": "stack_panel", "anchor_from": "top_middle", "anchor_to": "top_middle", "orientation": "horizontal", "collection_name": "container_items", "controls": [ { "in4@chest.ore_grinder_grid_item": { "collection_index": 4 } } ] },
  "slot_in_5": { "type": "stack_panel", "anchor_from": "top_middle", "anchor_to": "top_middle", "orientation": "horizontal", "collection_name": "container_items", "controls": [ { "in5@chest.ore_grinder_grid_item": { "collection_index": 5 } } ] },
  "slot_in_6": { "type": "stack_panel", "anchor_from": "top_middle", "anchor_to": "top_middle", "orientation": "horizontal", "collection_name": "container_items", "controls": [ { "in6@chest.ore_grinder_grid_item": { "collection_index": 6 } } ] },

  "slot_out_1": { "type": "stack_panel", "anchor_from": "top_middle", "anchor_to": "top_middle", "orientation": "horizontal", "collection_name": "container_items", "controls": [ { "out1@chest.ore_grinder_grid_item": { "collection_index": 7 } } ] },
  "slot_out_2": { "type": "stack_panel", "anchor_from": "top_middle", "anchor_to": "top_middle", "orientation": "horizontal", "collection_name": "container_items", "controls": [ { "out2@chest.ore_grinder_grid_item": { "collection_index": 8 } } ] },
  "slot_out_3": { "type": "stack_panel", "anchor_from": "top_middle", "anchor_to": "top_middle", "orientation": "horizontal", "collection_name": "container_items", "controls": [ { "out3@chest.ore_grinder_grid_item": { "collection_index": 9 } } ] },
  "slot_out_4": { "type": "stack_panel", "anchor_from": "top_middle", "anchor_to": "top_middle", "orientation": "horizontal", "collection_name": "container_items", "controls": [ { "out4@chest.ore_grinder_grid_item": { "collection_index": 10 } } ] },
  "slot_out_5": { "type": "stack_panel", "anchor_from": "top_middle", "anchor_to": "top_middle", "orientation": "horizontal", "collection_name": "container_items", "controls": [ { "out5@chest.ore_grinder_grid_item": { "collection_index": 11 } } ] },
  "slot_out_6": { "type": "stack_panel", "anchor_from": "top_middle", "anchor_to": "top_middle", "orientation": "horizontal", "collection_name": "container_items", "controls": [ { "out6@chest.ore_grinder_grid_item": { "collection_index": 12 } } ] },

  "ore_grinder_panel_top_half": {
    "type": "panel",
    "size": ["100%", "25%"],
    "anchor_to": "top_middle",
    "anchor_from": "top_middle",
    "offset": [0, 27],
    "controls": [
      // { "ore_grinder_background@chest.ore_grinder_background": {} },
      { "ore_grinder_label@chest.ore_grinder_label": {} },
      { "close@common.close_button": { "layer": 4, "offset": [0, -25] } },

      { "slot_fuel@chest.slot_fuel": { "offset": [-58, 3] } },

      { "slot_in_1@chest.slot_in_1": { "offset": [-34, -9] } },
      { "slot_in_2@chest.slot_in_2": { "offset": [-16, -9] } },
      { "slot_in_3@chest.slot_in_3": { "offset": [2, -9] } },
      { "slot_in_4@chest.slot_in_4": { "offset": [20, -9] } },
      { "slot_in_5@chest.slot_in_5": { "offset": [38, -9] } },
      { "slot_in_6@chest.slot_in_6": { "offset": [56, -9] } },

      { "slot_out_1@chest.slot_out_1": { "offset": [-34, 13] } },
      { "slot_out_2@chest.slot_out_2": { "offset": [-16, 13] } },
      { "slot_out_3@chest.slot_out_3": { "offset": [2, 13] } },
      { "slot_out_4@chest.slot_out_4": { "offset": [20, 13] } },
      { "slot_out_5@chest.slot_out_5": { "offset": [38, 13] } },
      { "slot_out_6@chest.slot_out_6": { "offset": [56, 13] } }
    ]
  },

  "ore_grinder_panel": {
  "type": "panel",
    "$background_image_control_name": "bg",
    "$background_images": "furnace.empty",
    "$chest_image": "textures/gui/inventory/oregrinder_image",
    "$size": [
      "150%",
      "150%"
    ],
    "$offset": [
      "5%",
      "10%"
    ],
    "$title_text_color": [
      1,
      1,
      1
    ],
  "controls": [
    { "container_gamepad_helpers@common.container_gamepad_helpers": {} },
    { "flying_item_renderer@common.flying_item_renderer": { "layer": 14 } },
    { "selected_item_details_factory@common.selected_item_details_factory": {} },
    { "item_lock_notification_factory@common.item_lock_notification_factory": {} },
    {
      "root_panel@common.root_panel": {
        "layer": 1,
        "controls": [
          {
            "image_background": {
              "type": "image",
              "size": "$size",
              "offset": "$offset",
              "texture": "$chest_image"
            }
          },
          {
            "chest_panel": {
              "type": "panel",
              "layer": 5,
              "controls": [
                { "ore_grinder_panel_top_half@chest.ore_grinder_panel_top_half": {} },
                { "inventory_panel_bottom_half_with_label@common.inventory_panel_bottom_half_with_label": { "offset": [1, -1] } },
                { "hotbar_grid@common.hotbar_grid_template": { "offset": [1, -6] } },
                { "inventory_take_progress_icon_button@common.inventory_take_progress_icon_button": {} }
              ]
            }
          },
          { "inventory_selected_icon_button@common.inventory_selected_icon_button": {} },
          { "gamepad_cursor@common.gamepad_cursor_button": {} }
        ]
      }
    }
  ]
}
}