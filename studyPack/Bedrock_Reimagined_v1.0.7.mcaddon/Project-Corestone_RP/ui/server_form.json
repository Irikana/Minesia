{
  "namespace": "server_form",
  "third_party_server_screen@common.base_screen": {
    "size": [
      "100%",
      "100%"
    ],
    "$screen_content": "server_form.main_screen_content"
    //   {
    //     "from_button_id": "button.slot0",
    //     "to_button_id": "button.menu_exit",
    //     "mapping_type": "global"
    //   }
    // ]
  },
  "main_screen_content": {
    "type": "panel",
    "size": [
      "100%",
      "100%"
    ],
    "controls": [
      {
        "server_form_factory": {
          "size": [
            "100%",
            "100%"
          ],
          "type": "factory",
          "control_ids": {
            "long_form": "@server_form.long_form",
            "custom_form": "@server_form.custom_form"
          }
        }
      }
    ]
  },
  "long_form": {
    "type": "panel",
    "controls": [
      {
        "vanilla_form@common_dialogs.main_panel_no_buttons": {
          "$title_panel": "common_dialogs.standard_title_label",
          "$title_size": [
            "100% - 14px",
            10
          ],
          "size": [
            225,
            200
          ],
          "$text_name": "#title_text",
          "$title_text_binding_type": "none",
          "$child_control": "server_form.long_form_panel",
          "layer": 2,
          "bindings": [
            {
              "binding_name": "#title_text",
              "binding_name_override": "#text",
              "binding_type": "global"
            },
            {
              "binding_type": "view", // make this a viewing binding
              "source_property_name": "(not (#text = 'hello') and not(#text = 'Progression') and not(#text = 'Life & Bonds') and not(#text = 'Advancements') and not(#text = 'Advancements II') and not(#text = 'Adventure') and not(#text = 'Exploration') and not(#text = 'Magic') and not(#text = 'The End') and not(#text = 'Nature & Growth') and not(#text = 'Nether'))", // detect when the title text string is not equal to "hello world"
              "target_property_name": "#visible" // override the #visibility property depending on if "source_property_name" is true or false
            }
          ]
        }
      },
      {
        "scroll_panel@elements_advantcements_5fs.root_root_panel": {
          "bindings": [
            {
              "binding_name": "#title_text",
              "binding_name_override": "#text",
              "binding_type": "global"
            },
            {
              "binding_type": "view", // make this a viewing binding
              "source_property_name": "((#text = 'hello'))", // detect when the title text string is not equal to "hello world"
              "target_property_name": "#visible" // override the #visibility property depending on if "source_property_name" is true or false
            }
          ]

        }
      },
