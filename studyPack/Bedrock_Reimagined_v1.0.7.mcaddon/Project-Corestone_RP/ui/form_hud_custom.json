        "$detect_text|default": "slider_1",
        "bindings": [
            {
                "binding_name": "#title_text",
                "binding_name_override": "#text",
                "binding_type": "global"
            },
            {
                "binding_type": "view", // make this a viewing binding
                "source_property_name": "(  not (( #text - $detect_text) = #text))", // detect when the title text string is not equal to "hello world"
                "target_property_name": "#visible" // override the #visibility property depending on if "source_property_name" is true or false
            }
        ]
    },
    "root_panel_form_custom": {
        "type": "panel",
        "size": [
            "100%",
            "100%"
        ],
        "controls": [
            {
                "data_element": {
                    "type": "panel",
                    "$update_string": "slider_",
                    "property_bag": {
                        "#text_0":"",
                        "#text_data_0": "",
                        "#text_data_1": "",
                        "#text_data_2": "",
                        "#text_data_3": "",
                        "#text_data_4": "",
                        "#split_seperator": ","
                    },
                    "bindings": [
                        {
                            "binding_name": "#title_text"
                            // "binding_name_override": "#text_0",
                            // "binding_type": "global"
                        },
                        {
                            "binding_type": "view",
                            "source_property_name": "( #title_text - $update_string)",
                            "target_property_name": "#text_data_0"
                        },
                        {
                            "binding_type": "view",
                            "source_property_name": "( #title_text - ($update_string + #text_data_0 + #split_seperator))",
                            "target_property_name": "#text_data_1"
                        },
                        {
                            "binding_type": "view",
                            "source_property_name": "( #title_text - ($update_string + #text_data_0 + #split_seperator + #text_data_1 + #split_seperator))",
                            "target_property_name": "#text_data_2"
                        },
                        {
                            "binding_type": "view",
                            "source_property_name": "( #title_text - ($update_string + #text_data_0 + #split_seperator + #text_data_1 + #split_seperator + #text_data_2 + #split_seperator))",
                            "target_property_name": "#text_data_3"
                        },
                        {
                            "binding_type": "view",
                            "source_property_name": "( #title_text - ($update_string + #text_data_0 + #split_seperator + #text_data_1 + #split_seperator + #text_data_2 + #split_seperator + #text_data_3 + #split_seperator))",
                            "target_property_name": "#text_data_4"
                        }
                    ]
                }
            },
            {
                "size@form_hud_custom.elemtns": {
                    "$detect_text": "slider_1",
                    "$bindings_edit": [
                        {
                            "binding_type": "view",
                            "source_control_name": "size_slider",
                            "source_property_name": "#custom_slider_step_value",
                            "target_property_name": "#custom_slider_step_value",
                            "resolve_sibling_scope": true
                        },
                        /// GET VALS
                        {
                            "binding_type": "view",
                            "source_control_name": "data_element",
                            "source_property_name": "(#text_data_1)",
                            "target_property_name": "#text_data_1"
                        },
                        {
                            "binding_type": "view",
                            "source_control_name": "data_element",
                            "source_property_name": "(#text_data_2)",
                            "target_property_name": "#text_data_2"
                        },
                        {
                            "binding_type": "view",
                            "source_control_name": "data_element",
                            "source_property_name": "(#text_data_3)",
                            "target_property_name": "#text_data_3"
                        },
                        {
                            "binding_type": "view",
                            "source_control_name": "data_element",
                            "source_property_name": "(#text_data_4)",
                            "target_property_name": "#text_data_4"
                        },
                        // SET DATA DEFAULT


                        {
                            "binding_type": "view",
                            "source_property_name": "(#text_data_2 * #multiplier_offset_y)",
                            "target_property_name": "#anchored_offset_value_y"
                        },
                        {
                            "binding_type": "view",
                            "source_property_name": "(#text_data_3 * #multiplier_offset_x)",
                            "target_property_name": "#anchored_offset_value_x"
                        },
                        {
                            "binding_type": "view",
                            "source_property_name": "(#text_data_4 * #multiplier_preset)",
                            "target_property_name": "#alpha"
                        },

                        // SET VARIABLE DATA
                        {
                            "binding_type": "view",
                            "source_property_name": "(#custom_slider_step_value * #multiplier)",
                            "target_property_name": "#size_binding_x"
                        }
                    ]
                }
            },
            {
                "offset_y@form_hud_custom.elemtns": {
                    "$detect_text": "slider_2",
