{
    "namespace": "waila_hud",

    "inspecting_display_hud": {
        "$update_string": "inspecting:",
        "$aux_display_string": "§a§u§x",
        "$entity_display_string": "§e§n§t",
        "$screen_offset|default": [
            0,
            5
        ],
        "type": "panel",
        "size": [
            "100%cm",
            "100%cm"
        ],
        "offset": "$screen_offset",
        "anchor_from": "top_middle",
        "anchor_to": "top_middle",
        "variables": [
            {
                "requires": "$pocket_edition",
                "$screen_offset": [
                    0,
                    22
                ]
            }
        ],
        "controls": [
            {
                "data_control_waila": {
                    "type": "panel",
                    "size": [
                        0,
                        0
                    ],
                    "property_bag": {
                        "#preserved_inspecting_display": ""
                    },
                    "bindings": [
                        {
                            "binding_name": "#hud_title_text_string"
                        },
                        {
                            "binding_name": "#hud_title_text_string",
                            "binding_name_override": "#preserved_inspecting_display",
                            "binding_condition": "visibility_changed"
                        },
                        {
                            "binding_type": "view",
                            "source_property_name": "(not (#hud_title_text_string = #preserved_inspecting_display) and not ((#hud_title_text_string - $update_string) = #hud_title_text_string))",
                            "target_property_name": "#visible"
                        }
                    ]
                }
            },
            {
                "stored_entity_id": {
                    "type": "panel",
                    "size": [
                        0,
                        0
                    ],
                    "property_bag": {
                        "#stored_entity_id": ""
                    },
                    "bindings": [
                        {
                            "binding_name": "#hud_subtitle_text_string"
                        },
                        {
                            "binding_name": "#hud_subtitle_text_string",
                            "binding_name_override": "#stored_entity_id",
                            "binding_condition": "visibility_changed"
                        },
                        {
                            "binding_type": "view",
                            "source_control_name": "data_control_waila",
                            "source_property_name": "((#preserved_inspecting_display - $entity_display_string) = #preserved_inspecting_display)",
                            "target_property_name": "#visible"
                        }
                    ]
                }
            },
            {
                "display_background": {
                    "type": "image",
                    "texture": "textures/gui/hud/inspecting_hud_background",
                    "size": [
                        "100%c + 10px",
                        "100%c + 10px"
                    ],
                    "controls": [
                        {
                            "display_stack": {
                                "type": "stack_panel",
                                "orientation": "horizontal",
                                "size": [
                                    "100%c",
                                    "100%cm"
                                ],
                                "controls": [
                                    {
                                        "image_display_panel": {
                                            "type": "panel",
                                            "size": [
                                                20,
                                                "100%sm"
                                            ],
                                            "max_size": [
                                                "100%y",
                                                "100%sm"
                                            ],
                                            "controls": [
                                                {
                                                    "item_display@beacon.item_renderer": {
                                                        "size": [
                                                            "100%",
                                                            "100%x"
                                                        ],
                                                        "anchor_from": "center",
                                                        "anchor_to": "center",
                                                        "bindings": [
                                                            {
                                                                "binding_type": "view",
                                                                "source_control_name": "data_control_waila",
                                                                "source_property_name": "(#preserved_inspecting_display - $update_string)",
                                                                "target_property_name": "#inspecting_aux_id_text"
                                                            },
                                                            {
                                                                "binding_type": "view",
                                                                "source_property_name": "(((%.20s * #inspecting_aux_id_text) - '\t' - $aux_display_string) * 1)",
                                                                "target_property_name": "#item_id_aux"
                                                            },
                                                            {
                                                                "binding_type": "view",
                                                                "source_property_name": "(not ((#inspecting_aux_id_text - $aux_display_string) = #inspecting_aux_id_text))",
                                                                "target_property_name": "#visible"
                                                            }
                                                        ]
                                                    }
                                                },
                                                {
                                                    "entity_display": {
                                                        "type": "custom",
                                                        "size": [
                                                            "100% - 10px",
                                                            "100%x"
                                                        ],
                                                        "offset": [
                                                            0,
                                                            7
                                                        ],
                                                        "renderer": "live_horse_renderer",
                                                        "layer": 20,
                                                        "anchor_from": "center",
                                                        "anchor_to": "center",
                                                        "property_bag": {
                                                            "#look_at_cursor": "false"
                                                        },
                                                        "bindings": [
                                                            {
                                                                "binding_type": "view",
                                                                "source_control_name": "stored_entity_id",
                                                                "source_property_name": "#stored_entity_id",
                                                                "target_property_name": "#entity_id"
                                                            }
                                                        ]
                                                    }
                                                }
                                            ],
                                            "bindings": [
                                                {
                                                    "binding_type": "view",
                                                    "source_control_name": "data_control_waila",
                                                    "source_property_name": "(#preserved_inspecting_display - $update_string)",
                                                    "target_property_name": "#inspecting_aux_id_text"
                                                },
                                                {
                                                    "binding_type": "view",
                                                    "source_property_name": "(not ((#inspecting_aux_id_text - $aux_display_string - $entity_display_string) = #inspecting_aux_id_text))",
                                                    "target_property_name": "#visible"
                                                }
                                            ]
                                        }
                                    },
                                    {
                                        "display_padding": {
                                            "type": "panel",
                                            "size": [
                                                4,
                                                0
                                            ],
                                            "bindings": [
                                                {
                                                    "binding_type": "view",
                                                    "source_control_name": "data_control_waila",
                                                    "source_property_name": "(#preserved_inspecting_display - $update_string)",
                                                    "target_property_name": "#inspecting_aux_id_text"
                                                },
                                                {
                                                    "binding_type": "view",
                                                    "source_property_name": "(not ((#inspecting_aux_id_text - $aux_display_string - $entity_display_string) = #inspecting_aux_id_text))",
                                                    "target_property_name": "#visible"
                                                }
                                            ]
                                        }
                                    },
                                    {
                                        "text_display": {
                                            "type": "label",
                                            "text": "#inspecting_text_subbed",
                                            "shadow": true,
                                            "max_size": [
                                                200,
                                                "default"
                                            ],
                                            "bindings": [
                                                {
                                                    "binding_type": "view",
                                                    "source_control_name": "data_control_waila",
                                                    "source_property_name": "(#preserved_inspecting_display - $update_string)",
                                                    "target_property_name": "#inspecting_text"
                                                },
                                                {
                                                    "binding_type": "view",
                                                    "source_property_name": "(((#inspecting_text) - (%.20s * #inspecting_text)) - '\t')",
                                                    "target_property_name": "#inspecting_text_subbed"
                                                }
                                            ]
                                        }
                                    }
                                ]
                            }
                        }
                    ],
                    "bindings": [
                        {
                            "binding_type": "view",
                            "source_control_name": "data_control_waila",
                            "source_property_name": "(not ((#preserved_inspecting_display) - (%.11s * #preserved_inspecting_display)) = '')",
                            "target_property_name": "#visible"
                        }
                    ]
                }
            }
        ]
    }
}