{
    "namespace": "accessory_common",
    "accessories_slots": {
        "type": "image",
        "layer": 2,
        "size": [
            16,
            16
        ],
        "bindings": [
            {
                "binding_type": "collection_details",
                "binding_collection_name": "$item_collection_name"
            },
            {
                "binding_name": "#item_id_aux",
                "binding_type": "collection",
                "binding_collection_name": "$item_collection_name",
                "binding_condition": "none"
            },
            {
                "binding_type": "view",
                "source_property_name": "(not(#item_id_aux > 0))",
                "target_property_name": "#visible"
            }
        ]
    },
    "accessory_slot_locked": {
        "type": "panel",
        "size": [
            16,
            16
        ],
        "controls": [
            {
                "locked_button@common_buttons.light_content_button": {
                    "size": [
                        16,
                        16
                    ],
                    "$button_content": "accessory_common.locked_content",
                    "$pressed_button_name": "button.invalid"
                }
            }
        ]
    },
    "locked_button_template@common_buttons.light_content_button": {
        "size": [
            16,
            16
        ],
        "$button_content": "accessory_common.locked_content",
        "$pressed_button_name": "button.invalid"
    },
    "locked_content": {
        "type": "panel",
        "controls": [
            {
                "lock_icon": {
                    "type": "image",
                    "texture": "textures/gui/slot_locked",
                    "size": [
                        16,
                        16
                    ]
                }
            },
            {
                "lock_hover_text@common.hover_text": {
                    "ignored": "$default_state",
                    "property_bag": {
                        "#hover_text": "Upgrade Accessory Bag to Unlock"
                    }
                }
            }
        ]
    },
    "slot_hat@accessory_common.accessories_slots": {
        "texture": "textures/gui/slot_hat"
    },
    "slot_talisman@accessory_common.accessories_slots": {
        "texture": "textures/gui/slot_talisman"
    },
    "slot_ring@accessory_common.accessories_slots": {
        "texture": "textures/gui/slot_ring"
    },
    "slot_belt@accessory_common.accessories_slots": {
        "texture": "textures/gui/slot_belt"
    },
    "accessories_item_bg": {
        "type": "image",
        "texture": "textures/gui/inventory/empty",
        "size": [
            16,
            16
        ]
    }
}