{
	"format_version": "1.10.0",
	"animation_controllers": {
		"controller.animation.coffin": {
			"initial_state": "close",
			"states": {
				"close": {
					"animations": [
						"close"
					],
					"transitions": [
						{
							"open": "q.property('5fs_br:is_opened')"
						}
					]
				},
				"open": {
					"animations": [
						"open"
					],
					"transitions": [
						{
							"close": "!q.property('5fs_br:is_opened')"
						}
					]
				}
			}
		}
	}
}
