{
    "format_version": "1.10.0",
    "animation_controllers": {
        "controller.animation.goblin.root": {
            "initial_state": "default",
            "states": {
                "default": {
                    "animations": [
                        "general_controller", "attack_controller", "look_at_target"
                    ],
                    "transitions": [
                        {
                            "death": "!q.is_alive"
                        }
                    ],
                    "blend_transition": 0.2
                },
                "death": {
                    "animations": [
                        "death"
                    ]
                }
            }
        },
        "controller.animation.goblin.general": {
            "initial_state": "default",
            "states": {
                "default": {
                    "animations": [
                        "idle_0"
                    ],
                    "transitions": [
                        {
                            "idle_0": "q.any_animation_finished"
                        },
                        {
                            "walk": "q.is_moving"
                        }
                    ],
                    "blend_transition": 0.2
                },
                "idle_0": {
                    "on_entry": [
                        "v.random_idle = math.random_integer(0, 4);"
                    ],
                    "animations": [
                        {
                            "idle_0": "v.random_idle < 4"
                        },
                        {
                            "idle_1": "v.random_idle == 4"
                        }
                    ],
                    "transitions": [
                        {
                            "idle_1": "q.any_animation_finished"
                        },
                        {
                            "walk": "q.is_moving"
                        }
                    ],
                    "blend_transition": 0.2
                },
                "idle_1": {
                    "on_entry": [
                        "v.random_idle = math.random_integer(0, 4);"
                    ],
                    "animations": [
                        {
                            "idle_0": "v.random_idle < 4"
                        },
                        {
                            "idle_1": "v.random_idle == 4"
                        }
                    ],
                    "transitions": [
                        {
                            "idle_0": "q.any_animation_finished"
                        },
                        {
                            "walk": "q.is_moving"
                        }
                    ],
                    "blend_transition": 0.2
                },
                "walk": {
                    "animations": [
                        "walk"
                    ],
                    "transitions": [
                        {
                            "default": "!q.is_moving"
                        }
                    ],
                    "blend_transition": 0.2
                }
            }
        },
        "controller.animation.goblin.attack": {
            "initial_state": "default",
            "states": {
                "default": {
                    "transitions": [
                        {
                            "attack": "q.is_delayed_attacking"
                        }
                    ],
                    "blend_transition": 0.2
                },
                "attack": {
                    "animations": [
                        "attack"
                    ],
                    "transitions": [
                        {
                            "default": "!q.is_delayed_attacking"
                        }
                    ],
                    "blend_transition": 0.2
                }
            }
        }
    }
}