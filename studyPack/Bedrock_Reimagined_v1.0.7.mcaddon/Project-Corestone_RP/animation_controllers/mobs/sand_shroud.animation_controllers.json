{
    "format_version": "1.10.0",
    "animation_controllers": {
        "controller.animation.sand_shroud.root": {
            "initial_state": "default",
            "states": {
                "default": {
                    "animations": [
                        "general_controller", "attack_controller", "spawn_controller", "look_at_target"
                    ],
                    "transitions": [
                        {
                            "death": "!q.is_alive"
                        }
                    ],
                    "blend_transition": 0.2
                },
                "death": {
                    "animations": [
                        "death"
                    ]
                }
            }
        },
        "controller.animation.sand_shroud.general": {
            "initial_state": "default",
            "states": {
                "default": {
                    "animations": [
                        "idle"
                    ],
                    "transitions": [
                        {
                            "walk": "q.modified_move_speed > 0.025"
                        },
                        {
                            "sit_down": "q.timer_flag_1"
                        },
                        {
                            "sit": "q.is_stunned && !q.timer_flag_1 && !q.timer_flag_2"
                        }
                    ],
                    "blend_transition": 0.2
                },
                "walk": {
                    "animations": [
                        "walk"
                    ],
                    "transitions": [
                        {
                            "default": "q.modified_move_speed <= 0.025"
                        },
                        {
                            "sit_down": "q.timer_flag_1"
                        },
                        {
                            "sit": "q.is_stunned && !q.timer_flag_1 && !q.timer_flag_2"
                        }
                    ],
                    "blend_transition": 0.2
                },
                "sit_down": {
                    "animations": [
                        "sit_down"
                    ],
                    "transitions": [
                        {
                            "default": "q.modified_move_speed <= 0.025 && !q.timer_flag_1 && !q.is_stunned"
                        },
                        {
                            "walk": "q.modified_move_speed > 0.025 && !q.timer_flag_1 && !q.is_stunned"
                        },
                        {
                            "sit": "q.is_stunned && !q.timer_flag_1"
                        }
                    ],
                    "blend_transition": 0.2
                },
                "sit": {
                    "animations": [
                        "sit"
                    ],
                    "transitions": [
                        {
                            "default": "q.modified_move_speed <= 0.025 && !q.is_stunned && !q.timer_flag_1 && !q.timer_flag_2"
                        },
                        {
                            "walk": "q.modified_move_speed > 0.025 && !q.is_stunned && !q.timer_flag_1 && !q.timer_flag_2"
                        },
                        {
                            "stand_up": "q.timer_flag_2"
                        }
                    ],
                    "blend_transition": 0.2
                },
                "stand_up": {
                    "animations": [
                        "stand_up"
                    ],
                    "transitions": [
                        {
                            "default": "q.modified_move_speed <= 0.025 && !q.timer_flag_2 && !q.is_stunned"
                        },
                        {
                            "walk": "q.modified_move_speed > 0.025 && !q.timer_flag_2 && !q.is_stunned"
                        }
                    ],
                    "blend_transition": 0.2
                }
            }
        },
        "controller.animation.sand_shroud.attack": {
            "initial_state": "default",
            "states": {
                "default": {
                    "transitions": [
                        {
                            "attack": "v.attack_time > 0.0"
                        }
                    ],
                    "blend_transition": 0.2
                },
                "attack": {
                    "animations": [
                        "attack"
                    ],
                    "transitions": [
                        {
                            "default": "q.all_animations_finished"
                        }
                    ],
                    "blend_transition": 0.2
                }
            }
        },
        "controller.animation.sand_shroud.emerging": {
            "initial_state": "default",
            "states": {
                "default": {
                    "transitions": [
                        {
                            "spawn": "q.is_emerging"
                        }
                    ]
                },
                "spawn": {
                    "animations": [
                        "spawn"
                    ],
                    "transitions": [
                        {
                            "default": "!q.is_emerging"
                        }
                    ],
                    "blend_transition": 0.2
                }
            }
        }
    }
}