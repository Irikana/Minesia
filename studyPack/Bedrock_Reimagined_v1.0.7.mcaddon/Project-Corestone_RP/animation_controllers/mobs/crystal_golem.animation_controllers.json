{
    "format_version": "1.10.0",
    "animation_controllers": {
        "controller.animation.crystal_golem.root": {
            "initial_state": "default",
            "states": {
                "default": {
                    "animations": [
                        "general_controller", "look_at_target"
                    ],
                    "transitions": [
                        {
                            "death": "!q.is_alive"
                        }
                    ],
                    "blend_transition": 0.2
                },
                "death": {
                    "animations": [
                        "death"
                    ]
                }
            }
        },
        "controller.animation.crystal_golem.general": {
            "initial_state": "default",
            "states": {
                "default": {
                    "animations": [
                        "idle"
                    ],
                    "transitions": [
                        {
                            "idle": "q.any_animation_finished"
                        },
                        {
                            "walk": "q.modified_move_speed > 0.02"
                        },
                        {
                            "melee_attack": "q.is_delayed_attacking"
                        },
                        {
                            "slam_attack": "q.is_roaring"
                        },
                        {
                            "throw_attack": "q.is_charged"
                        }
                    ],
                    "blend_transition": 0.2
                },
                "idle": {
                    "on_entry": [
                        "v.random_idle = math.random_integer(0, 3);"
                    ],
                    "animations": [
                        {
                            "idle": "v.random_idle < 3"
                        },
                        {
                            "special_idle": "v.random_idle == 3"
                        }
                    ],
                    "transitions": [
                        {
                            "special_idle": "q.any_animation_finished"
                        },
                        {
                            "walk": "q.modified_move_speed > 0.02"
                        },
                        {
                            "melee_attack": "q.is_delayed_attacking"
                        },
                        {
                            "slam_attack": "q.is_roaring"
                        },
                        {
                            "throw_attack": "q.is_charged"
                        }
                    ],
                    "blend_transition": 0.2
                },
                "special_idle": {
                    "on_entry": [
                        "v.random_idle = math.random_integer(0, 3);"
                    ],
                    "animations": [
                        {
                            "idle": "v.random_idle < 3"
                        },
                        {
                            "special_idle": "v.random_idle == 3"
                        }
                    ],
                    "transitions": [
                        {
                            "special_idle": "q.any_animation_finished"
                        },
                        {
                            "walk": "q.modified_move_speed > 0.02"
                        },
                        {
                            "melee_attack": "q.is_delayed_attacking"
                        },
                        {
                            "slam_attack": "q.is_roaring"
                        },
                        {
                            "throw_attack": "q.is_charged"
                        }
                    ],
                    "blend_transition": 0.2
                },
                "walk": {
                    "animations": [
                        "walk"
                    ],
                    "transitions": [
                        {
                            "default": "q.modified_move_speed <= 0.02"
                        },
                        {
                            "melee_attack": "q.is_delayed_attacking"
                        },
                        {
                            "slam_attack": "q.is_roaring"
                        },
                        {
                            "throw_attack": "q.is_charged"
                        }
                    ],
                    "blend_transition": 0.2
                },
                "melee_attack": {
                    "animations": [
                        "melee_attack"
                    ],
                    "transitions": [
                        {
                            "default": "q.modified_move_speed <= 0.02 && !q.is_delayed_attacking"
                        },
                        {
                            "walk": "q.modified_move_speed > 0.02 && !q.is_delayed_attacking"
                        },
                        {
                            "slam_attack": "q.is_roaring"
                        },
                        {
                            "throw_attack": "q.is_charged"
                        }
                    ],
                    "blend_transition": 0.2
                },
                "slam_attack": {
                    "animations": [
                        "slam_attack"
                    ],
                    "transitions": [
                        {
                            "default": "q.modified_move_speed <= 0.02 && !q.is_roaring"
                        },
                        {
                            "walk": "q.modified_move_speed > 0.02 && !q.is_roaring"
                        },
                        {
                            "melee_attack": "q.is_delayed_attacking"
                        },
                        {
                            "throw_attack": "q.is_charged"
                        }
                    ],
                    "blend_transition": 0.2
                },
                "throw_attack": {
                    "animations": [
                        "throw_attack"
                    ],
                    "transitions": [
                        {
                            "default": "q.modified_move_speed <= 0.02 && q.all_animations_finished"
                        },
                        {
                            "walk": "q.modified_move_speed > 0.02 && q.all_animations_finished"
                        },
                        {
                            "melee_attack": "q.is_delayed_attacking"
                        },
                        {
                            "slam_attack": "q.is_roaring"
                        }
                    ],
                    "blend_transition": 0.2
                }
            }
        }
    }
}