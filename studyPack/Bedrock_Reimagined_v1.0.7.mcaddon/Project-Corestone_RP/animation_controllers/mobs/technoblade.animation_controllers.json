{
  "format_version": "1.10.0",
  "animation_controllers": {
    "controller.animation.technoblade": {
      "initial_state": "default",
      "states": {
        "default": {
          "animations": [
            { "idle": "q.is_alive" },
            { "walking": "q.modified_move_speed > 0.05 && q.modified_move_speed <= 0.25 && q.is_alive" },
            { "running": "q.modified_move_speed > 0.25 && q.is_alive" },
            { "eating_carrots": "q.is_eating && q.is_alive" },
            { "death": "!q.is_alive" }
          ]
        }
      }
    }
  }
}