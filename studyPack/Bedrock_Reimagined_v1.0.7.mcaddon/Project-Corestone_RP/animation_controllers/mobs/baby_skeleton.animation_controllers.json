{
    "format_version": "1.10.0",
    "animation_controllers": {
        "controller.animation.baby_skeleton.root": {
            "initial_state": "default",
            "states": {
                "default": {
                    "animations": [
                        "general_controller", "attack_controller", "look_at_target"
                    ],
                    "transitions": [
                        {
                            "death": "!q.is_alive"
                        }
                    ],
                    "blend_transition": 0.2
                },
                "death": {
                    "animations": [
                        "death"
                    ]
                }
            }
        },
        "controller.animation.baby_skeleton.general": {
            "initial_state": "default",
            "states": {
                "default": {
                    "animations": [
                        "idle_0"
                    ],
                    "transitions": [
                        {
                            "walk": "q.is_moving"
                        }
                    ],
                    "blend_transition": 0.2
                },
                "walk": {
                    "animations": [
                        "walk"
                    ],
                    "transitions": [
                        {
                            "default": "!q.is_moving"
                        }
                    ],
                    "blend_transition": 0.2
                }
            }
        },
        "controller.animation.skeleton_bomber.general": {
            "initial_state": "default",
            "states": {
                "default": {
                    "animations": [
                        "idle_0"
                    ],
                    "transitions": [
                        {
                            "walk": "q.is_moving"
                        }
                    ],
                    "blend_transition": 0.2
                },
                "walk": {
                    "animations": [
                        "walk"
                    ],
                    "transitions": [
                        {
                            "default": "!q.is_moving"
                        }
                    ],
                    "blend_transition": 0.2
                }
            }
        },
        "controller.animation.baby_skeleton.attack": {
            "initial_state": "default",
            "states": {
                "default": {
                    "transitions": [
                        {
                            "shoot": "q.is_charged && !q.is_avoiding_mobs"
                        }
                    ],
                    "blend_transition": 0.2
                },
                "shoot": {
                    "animations": [
                        "shoot"
                    ],
                    "transitions": [
                        {
                            "default": "q.all_animations_finished || q.is_avoiding_mobs"
                        }
                    ]
                }
            }
        }
    }
}