{
    "format_version": "1.10.0",
    "animation_controllers": {
        "controller.animation.deer.general": {
            "initial_state": "default",
            "states": {
                "default": {
                    "animations": [
                        "idle_0"
                    ],
                    "transitions": [
                        {
                            "walk": "query.modified_move_speed > 0.025 && query.modified_move_speed < 0.8 && !query.is_sheared"
                        },
                        {
                            "run": "query.modified_move_speed >= 0.8 && !query.is_sheared"
                        },
                        {
                            "sleep": "query.is_sheared"
                        }
                    ],
                    "blend_transition": 0.2
                },
                "walk": {
                    "animations": [
                        "walk"
                    ],
                    "transitions": [
                        {
                            "default": "query.modified_move_speed <= 0.025 && !query.is_sheared"
                        },
                        {
                            "run": "query.modified_move_speed >= 0.8 && !query.is_sheared"
                        },
                        {
                            "death": "!query.is_alive"
                        },
                        {
                            "sleep": "query.is_sheared"
                        }
                    ],
                    "blend_transition": 0.2
                },
                "run": {
                    "animations": [
                        "run"
                    ],
                    "transitions": [
                        {
                            "default": "query.modified_move_speed <= 0.025 && !query.is_sheared"
                        },
                        {
                            "walk": "query.modified_move_speed > 0.025 && query.modified_move_speed < 0.8 && !query.is_sheared"
                        },
                        {
                            "death": "!query.is_alive"
                        },
                        {
                            "sleep": "query.is_sheared"
                        }
                    ],
                    "blend_transition": 0.2
                },
                "sleep": {
                    "animations": [
                        "sleep"
                    ],
                    "transitions": [
                        {
                            "default": "query.modified_move_speed <= 0.025 && !query.is_sheared"
                        },
                        {
                            "walk": "query.modified_move_speed > 0.025 && query.modified_move_speed < 0.8 && !query.is_sheared"
                        },
                        {
                            "run": "query.modified_move_speed >= 0.8 && !query.is_sheared"
                        },
                        {
                            "death": "!query.is_alive"
                        }
                    ],
                    "blend_transition": 0.2
                },
                "death": {
                    "animations": [
                        "death"
                    ]
                }
            }
        },
        "controller.animation.deer.look_around_controller": {
            "initial_state": "default",
            "states": {
                "default": {
                    "transitions": [
                        {
                            "idle_1": "query.timer_flag_1"
                        }
                    ],
                    "blend_transition": 0.2
                },
                "idle_1": {
                    "animations": [
                        "idle_1"
                    ],
                    "transitions": [
                        {
                            "default": "!query.timer_flag_1"
                        }
                    ],
                    "blend_transition": 0.2
                }
            }
        },
        "controller.animation.deer.attack_controller": {
            "initial_state": "default",
            "states": {
                "default": {
                    "transitions": [
                        {
                            "attack": "query.is_delayed_attacking"
                        }
                    ],
                    "blend_transition": 0.2
                },
                "attack": {
                    "animations": [
                        "attack"
                    ],
                    "transitions": [
                        {
                            "default": "!query.is_delayed_attacking"
                        }
                    ],
                    "blend_transition": 0.2
                }
            }
        }
    }
}