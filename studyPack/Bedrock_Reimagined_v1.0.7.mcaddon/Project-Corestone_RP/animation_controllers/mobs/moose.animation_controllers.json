{
    "format_version": "1.10.0",
    "animation_controllers": {
         "controller.animation.moose.general": {
            "initial_state": "default",
            "states": {
                "default": {
                    "animations": [
                        "idle"
                    ],
                    "transitions": [
                        {
                            "walk": "query.modified_move_speed > 0.025 && query.modified_move_speed < 0.75 && !query.is_sheared"
                        },
                        {
                            "run": "query.modified_move_speed >= 0.75 && !query.is_sheared && !query.has_target"
                        },
                        {
                            "run_attack": "query.modified_move_speed >= 0.75 && !query.is_sheared && query.has_target"
                        },
                        {
                            "sleep": "query.is_sheared"
                        }
                    ],
                    "blend_transition": 0.2
                },
                "walk": {
                    "animations": [
                        "walk"
                    ],
                    "transitions": [
                        {
                            "default": "query.modified_move_speed <= 0.025 && !query.is_sheared"
                        },
                        {
                            "run": "query.modified_move_speed >= 0.75 && !query.is_sheared && !query.has_target"
                        },
                        {
                            "run_attack": "query.modified_move_speed >= 0.75 && !query.is_sheared && query.has_target"
                        },
                        {
                            "death": "!query.is_alive"
                        },
                        {
                            "sleep": "query.is_sheared"
                        }
                    ],
                    "blend_transition": 0.2
                },
                "run": {
                    "animations": [
                        "run"
                    ],
                    "transitions": [
                        {
                            "default": "query.modified_move_speed <= 0.025 && !query.is_sheared"
                        },
                        {
                            "walk": "query.modified_move_speed > 0.025 && query.modified_move_speed < 0.75 && !query.is_sheared"
                        },
                        {
                            "run_attack": "query.modified_move_speed >= 0.75 && !query.is_sheared && query.has_target"
                        },
                        {
                            "death": "!query.is_alive"
                        },
                        {
                            "sleep": "query.is_sheared"
                        }
                    ],
                    "blend_transition": 0.2
                },
                "run_attack": {
                    "animations": [
                        "run_attack"
                    ],
                    "transitions": [
                        {
                            "default": "query.modified_move_speed <= 0.025 && !query.is_sheared"
                        },
                        {
                            "walk": "query.modified_move_speed > 0.025 && query.modified_move_speed < 0.75 && !query.is_sheared"
                        },
                        {
                            "run": "query.modified_move_speed >= 0.75 && !query.is_sheared && !query.has_target"
                        },
                        {
                            "death": "!query.is_alive"
                        },
                        {
                            "sleep": "query.is_sheared"
                        }
                    ],
                    "blend_transition": 0.2
                },
                "sleep": {
                    "animations": [
                        "sleep"
                    ],
                    "transitions": [
                        {
                            "default": "query.modified_move_speed <= 0.025 && !query.is_sheared"
                        },
                        {
                            "walk": "query.modified_move_speed > 0.025 && query.modified_move_speed < 0.75 && !query.is_sheared"
                        },
                        {
                            "run": "query.modified_move_speed >= 0.75 && !query.is_sheared && !query.has_target"
                        },
                        {
                            "run_attack": "query.modified_move_speed >= 0.75 && !query.is_sheared && query.has_target"
                        },
                        {
                            "death": "!query.is_alive"
                        }
                    ],
                    "blend_transition": 0.2
                },
                "death": {
                    "animations": [
                        "death"
                    ]
                }
            }
        },
        "controller.animation.moose.charge_attack_controller": {
            "initial_state": "default",
            "states": {
                "default": {
                    "transitions": [
                        {
                            "charge_attack": "query.is_delayed_attacking"
                        }
                    ],
                    "blend_transition": 0.2
                },
                "charge_attack": {
                    "animations": [
                        "charge_attack"
                    ],
                    "transitions": [
                        {
                            "default": "!query.is_delayed_attacking"
                        }
                    ],
                    "blend_transition": 0.2
                }
            }
        },
        "controller.animation.moose.stomp_attack_controller": {
            "initial_state": "default",
            "states": {
                "default": {
                    "transitions": [
                        {
                            "stomp_attack": "query.is_roaring"
                        }
                    ],
                    "blend_transition": 0.2
                },
                "stomp_attack": {
                    "animations": [
                        "stomp_attack"
                    ],
                    "transitions": [
                        {
                            "default": "!query.is_roaring"
                        }
                    ],
                    "blend_transition": 0.2
                }
            }
        },
        "controller.animation.moose.drop_antlers_controller": {
            "initial_state": "default",
            "states": {
                "default": {
                    "transitions": [
                        {
                            "drop_antlers": "query.timer_flag_1"
                        }
                    ],
                    "blend_transition": 0.2
                },
                "drop_antlers": {
                    "animations": [
                        "drop_antlers"
                    ],
                    "transitions": [
                        {
                            "default": "!query.timer_flag_1"
                        }
                    ],
                    "blend_transition": 0.2
                }
            }
        }
    }
}