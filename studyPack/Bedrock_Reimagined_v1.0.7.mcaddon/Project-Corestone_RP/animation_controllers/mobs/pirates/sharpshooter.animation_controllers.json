{
    "format_version": "1.10.0",
    "animation_controllers": {
        "controller.animation.pirate_sharpshooter.root": {
            "initial_state": "default",
            "states": {
                "default": {
                    "animations": [
                        "general_controller", "look_at_target"
                    ],
                    "transitions": [
                        {
                            "death": "!q.is_alive"
                        }
                    ],
                    "blend_transition": 0.2
                },
                "death": {
                    "animations": [
                        "death"
                    ]
                }
            }
        },
        "controller.animation.pirate_sharpshooter.general": {
            "initial_state": "default",
            "states": {
                "default": {
                    "animations": [
                        "idle"
                    ],
                    "transitions": [
                        {
                            "walk": "q.is_moving"
                        },
                        {
                            "charge": "q.is_using_item"
                        }
                    ],
                    "blend_transition": 0.2
                },
                "walk": {
                    "animations": [
                        "walk"
                    ],
                    "transitions": [
                        {
                            "default": "!q.is_moving"
                        },
                        {
                            "charge": "q.is_using_item"
                        }
                    ],
                    "blend_transition": 0.2
                },
                "charge": {
                    "animations": [
                        "charge"
                    ],
                    "transitions": [
                        {
                            "charged": "q.is_charged"
                        }
                    ],
                    "blend_transition": 0.2
                },
                "charged": {
                    "animations": [
                        "target",
                        {
                            "walk_legs": "q.modified_move_speed"
                        }
                    ],
                    "transitions": [
                        {
                            "shoot": "!q.is_charged"
                        }
                    ],
                    "blend_transition": 0.2
                },
                "shoot": {
                    "animations": [
                        "shoot",
                        {
                            "walk_legs": "q.modified_move_speed"
                        }
                    ],
                    "transitions": [
                        {
                            "default": "q.all_animations_finished"
                        }
                    ],
                    "blend_transition": 0.2
                }
            }
        }
    }
}