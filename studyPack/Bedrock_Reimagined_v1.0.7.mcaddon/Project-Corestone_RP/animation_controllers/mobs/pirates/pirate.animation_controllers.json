{
    "format_version": "1.10.0",
    "animation_controllers": {
        "controller.animation.pirate.root": {
            "initial_state": "default",
            "states": {
                "default": {
                    "animations": [
                        "general_controller", "attack_controller", "look_at_target"
                    ],
                    "transitions": [
                        {
                            "death": "!q.is_alive"
                        }
                    ],
                    "blend_transition": 0.2
                },
                "death": {
                    "animations": [
                        "death"
                    ]
                }
            }
        },
        "controller.animation.pirate.general": {
            "initial_state": "default",
            "states": {
                "default": {
                    "animations": [
                        "idle"
                    ],
                    "transitions": [
                        {
                            "walk": "q.is_moving && !q.has_target"
                        },
                        {
                            "walk_target": "q.is_moving && q.has_target"
                        }
                    ],
                    "blend_transition": 0.2
                },
                "walk": {
                    "animations": [
                        "walk"
                    ],
                    "transitions": [
                        {
                            "default": "!q.is_moving"
                        },
                        {
                            "walk_target": "q.is_moving && q.has_target"
                        }
                    ],
                    "blend_transition": 0.2
                },
                "walk_target": {
                    "animations": [
                        "walk_target"
                    ],
                    "transitions": [
                        {
                            "default": "!q.is_moving"
                        },
                        {
                            "walk": "q.is_moving && !q.has_target"
                        }
                    ],
                    "blend_transition": 0.2
                }
            }
        },
        "controller.animation.pirate.attack": {
            "initial_state": "default",
            "states": {
                "default": {
                    "transitions": [
                        {
                            "attack": "q.is_delayed_attacking"
                        }
                    ],
                    "blend_transition": 0.2
                },
                "attack": {
                    "animations": [
                        "attack"
                    ],
                    "transitions": [
                        {
                            "default": "!q.is_delayed_attacking"
                        }
                    ],
                    "blend_transition": 0.2
                }
            }
        }
    }
}