{
    "format_version": "1.10.0",
    "animation_controllers": {
        "controller.animation.ombari.root": {
            "initial_state": "default",
            "states": {
                "default": {
                    "animations": [
                        "general_controller", "attack_controller", "look_at_target"
                    ],
                    "transitions": [
                        {
                            "death": "q.is_powered"
                        }
                    ],
                    "blend_transition": 0.2
                },
                "death": {
                    "animations": [
                        "death",
                        {
                            "death_rotation": "q.is_stackable"
                        }
                    ]
                }
            }
        },
        "controller.animation.ombari.general": {
            "initial_state": "default",
            "states": {
                "default": {
                    "animations": [
                        "idle"
                    ],
                    "transitions": [
                        {
                            "walk": "q.modified_move_speed > 0.01 && !q.is_in_water"
                        },
                        {
                            "swim": "q.modified_move_speed > 0.01 && q.is_in_water"
                        },
                        {
                            "roar": "q.timer_flag_1"
                        }
                    ],
                    "blend_transition": 0.2
                },
                "walk": {
                    "animations": [
                        "walk"
                    ],
                    "transitions": [
                        {
                            "default": "q.modified_move_speed <= 0.01 && !q.is_in_water"
                        },
                        {
                            "swim": "q.modified_move_speed > 0.01 && q.is_in_water"
                        },
                        {
                            "roar": "q.timer_flag_1"
                        }
                    ],
                    "blend_transition": 0.2
                },
                "swim": {
                    "animations": [
                        "swim"
                    ],
                    "transitions": [
                        {
                            "default": "q.modified_move_speed <= 0.01 && !q.is_in_water"
                        },
                        {
                            "walk": "q.modified_move_speed > 0.01 && !q.is_in_water"
                        },
                        {
                            "roar": "q.timer_flag_1"
                        }
                    ],
                    "blend_transition": 0.2
                },
                "roar": {
                    "animations": [
                        "roar"
                    ],
                    "transitions": [
                        {
                            "default": "q.modified_move_speed <= 0.01 && !q.timer_flag_1"
                        },
                        {
                            "walk": "q.modified_move_speed > 0.01 && !q.timer_flag_1"
                        },
                        {
                            "swim": "q.modified_move_speed > 0.01 && q.is_in_water && !q.timer_flag_1"
                        }
                    ],
                    "blend_transition": 0.2,
                    "blend_via_shortest_path": true
                }
            }
        },
        "controller.animation.ombari.attack": {
            "initial_state": "default",
            "states": {
                "default": {
                    "transitions": [
                        {
                            "melee_attack": "q.is_delayed_attacking"
                        },
                        {
                            "slam_attack": "q.is_roaring"
                        }
                    ],
                    "blend_transition": 0.2
                },
                "melee_attack": {
                    "animations": [
                        "attack"
                    ],
                    "transitions": [
                        {
                            "default": "q.all_animations_finished"
                        }
                    ],
                    "blend_transition": 0.2,
                    "blend_via_shortest_path": true
                },
                "slam_attack": {
                    "animations": [
                        "slam"
                    ],
                    "transitions": [
                        {
                            "default": "!q.is_roaring"
                        }
                    ],
                    "blend_transition": 0.2,
                    "blend_via_shortest_path": true
                }
            }
        }
    }
}