{
    "format_version": "1.10.0",
    "animation_controllers": {
        "controller.animation.groundhog.root": {
            "initial_state": "default",
            "states": {
                "default": {
                    "animations": [
                        "general_controller", "eat_controller", "look_at_target"
                    ],
                    "transitions": [
                        {
                            "death": "!q.is_alive"
                        }
                    ],
                    "blend_transition": 0.2
                },
                "death": {
                    "animations": [
                        "death"
                    ]
                }
            }
        },
        "controller.animation.groundhog.general": {
            "initial_state": "default",
            "states": {
                "default": {
                    "animations": [
                        "idle_0"
                    ],
                    "transitions": [
                        {
                            "idle_0": "q.any_animation_finished"
                        },
                        {
                            "walk": "q.is_moving"
                        },
                        {
                            "burry": "q.timer_flag_1"
                        },
                        {
                            "emerge": "q.timer_flag_2"
                        }
                    ],
                    "blend_transition": 0.2
                },
                "idle_0": {
                    "on_entry": [
                        "v.random_idle = math.random_integer(0, 6);"
                    ],
                    "animations": [
                        {
                            "idle_0": "v.random_idle < 5"
                        },
                        {
                            "idle_1": "v.random_idle == 5"
                        },
                        {
                            "idle_2": "v.random_idle == 6"
                        }
                    ],
                    "transitions": [
                        {
                            "idle_1": "q.any_animation_finished"
                        },
                        {
                            "walk": "q.is_moving"
                        },
                        {
                            "burry": "q.timer_flag_1"
                        },
                        {
                            "emerge": "q.timer_flag_2"
                        }
                    ],
                    "blend_transition": 0.2
                },
                "idle_1": {
                    "on_entry": [
                        "v.random_idle = math.random_integer(0, 6);"
                    ],
                    "animations": [
                        {
                            "idle_0": "v.random_idle < 5"
                        },
                        {
                            "idle_1": "v.random_idle == 5"
                        },
                        {
                            "idle_2": "v.random_idle == 6"
                        }
                    ],
                    "transitions": [
                        {
                            "idle_0": "q.any_animation_finished"
                        },
                        {
                            "walk": "q.is_moving"
                        },
                        {
                            "burry": "q.timer_flag_1"
                        },
                        {
                            "emerge": "q.timer_flag_2"
                        }
                    ],
                    "blend_transition": 0.2
                },
                "walk": {
                    "animations": [
                        "walk"
                    ],
                    "transitions": [
                        {
                            "default": "!q.is_moving"
                        },
                        {
                            "burry": "q.timer_flag_1"
                        },
                        {
                            "emerge": "q.timer_flag_2"
                        }
                    ],
                    "blend_transition": 0.2
                },
                "burry": {
                    "animations": [
                        "burry"
                    ],
                    "transitions": [
                        {
                            "in_ground": "q.all_animations_finished"
                        }
                    ],
                    "blend_transition": 0.2
                },
                "in_ground": {
                    "animations": [
                        "in_ground"
                    ],
                    "transitions": [
                        {
                            "emerge": "q.timer_flag_2"
                        }
                    ],
                    "blend_transition": 0.2
                },
                "emerge": {
                    "animations": [
                        "emerge"
                    ],
                    "transitions": [
                        {
                            "default": "q.all_animations_finished"
                        }
                    ],
                    "blend_transition": 0.2
                }
            }
        },
        "controller.animation.groundhog.eat": {
            "initial_state": "default",
            "states": {
                "default": {
                    "transitions": [
                        {
                            "eat": "query.is_eating"
                        }
                    ],
                    "blend_transition": 0.2
                },
                "eat": {
                    "animations": [
                        "eat"
                    ],
                    "transitions": [
                        {
                            "default": "!query.is_eating"
                        }
                    ],
                    "blend_transition": 0.2
                }
            }
        }
    }
}