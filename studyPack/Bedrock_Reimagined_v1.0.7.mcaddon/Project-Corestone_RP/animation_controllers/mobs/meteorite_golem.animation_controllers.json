{
    "format_version": "1.10.0",
    "animation_controllers": {
        "controller.animation.meteorite_golem.general": {
            "initial_state": "default",
            "states": {
                "default": {
                    "animations": [
                        "idle_0"
                    ],
                    "transitions": [
                        {
                            "walk": "query.modified_move_speed >= 0.05"
                        },
                        {
                            "idle_2": "query.is_sheared"
                        },
                        {
                            "double_arm_slam": "query.timer_flag_2"
                        },
                        {
                            "spin": "query.timer_flag_3"
                        },
                        {
                            "death": "!query.is_alive"
                        }
                    ],
                    "blend_transition": 0.2
                },
                "idle_2": {
                    "animations": [
                        "idle_2"
                    ],
                    "transitions": [
                        {
                            "default": "query.modified_move_speed < 0.05 && !query.is_sheared"
                        },
                        {
                            "walk": "query.modified_move_speed >= 0.05 && !query.is_sheared"
                        },
                        {
                            "death": "!query.is_alive"
                        }
                    ],
                    "blend_transition": 0.2
                },
                "walk": {
                    "animations": [
                        "walk"
                    ],
                    "transitions": [
                        {
                            "default": "query.modified_move_speed < 0.05 && !query.is_sheared"
                        },
                        {
                            "idle_2": "query.is_sheared"
                        },
                        {
                            "double_arm_slam": "query.timer_flag_2"
                        },
                        {
                            "spin": "query.timer_flag_3"
                        },
                        {
                            "death": "!query.is_alive"
                        }
                    ],
                    "blend_transition": 0.2
                },
                "double_arm_slam": {
                    "animations": [
                        "double_arm_slam"
                    ],
                    "transitions": [
                        {
                            "default": "query.modified_move_speed < 0.05 && !query.timer_flag_2"
                        },
                        {
                            "walk": "query.modified_move_speed >= 0.05 && !query.timer_flag_2"
                        },
                        {
                            "death": "!query.is_alive"
                        }
                    ],
                    "blend_transition": 0.2
                },
                "spin": {
                    "animations": [
                        "spin"
                    ],
                    "transitions": [
                        {
                            "default": "query.modified_move_speed < 0.05 && !query.timer_flag_3"
                        },
                        {
                            "walk": "query.modified_move_speed >= 0.05 && !query.timer_flag_3"
                        },
                        {
                            "death": "!query.is_alive"
                        }
                    ],
                    "blend_transition": 0.2
                },
                "death": {
                    "animations": [
                        "death"
                    ]
                }
            }
        }
    }
}