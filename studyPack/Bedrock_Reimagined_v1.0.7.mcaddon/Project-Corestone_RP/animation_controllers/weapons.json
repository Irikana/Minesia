{
	"format_version": "1.10.0",
	"animation_controllers": {
		"controller.animation.trident_general_5fs": {
			"states": {
				"default": {
					"animations": [
						{
							"fpp_idle": "c.is_first_person"
						}
					],
					"transitions": [
						{
							"fpp_ability": "(q.is_item_name_any('slot.weapon.mainhand',0, '5fs_br:meteorite_trident') || q.is_item_name_any('slot.weapon.mainhand',0, '5fs_br:dragonite_trident')) && q.cooldown_time_remaining('slot.weapon.mainhand') > 0 "
						}
					]
				},
				"fpp_ability": {
					"animations": [
						{
							"fpp_ability": "c.is_first_person"
						}
					],
					"transitions": [
						{
							"default": "q.all_animations_finished || q.cooldown_time_remaining('slot.weapon.mainhand') == 0"
						}
					]
				}
			}
		}
	}
}