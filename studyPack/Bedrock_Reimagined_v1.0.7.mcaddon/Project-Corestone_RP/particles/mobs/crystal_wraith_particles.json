{
  "format_version": "1.10.0",
  "particle_effect": {
    "description": {
      "identifier": "5fs_br:blue_crystal_dust",
      "basic_render_parameters": {
        "material": "particles_alpha",
        "texture": "textures/particles/yuan_1"
      }
    },
    "components": {
      "minecraft:emitter_initialization": {
        "creation_expression": "variable.size = 0.1; variable.lifetime = 1.0;",
        "per_update_expression": "variable.emitter_age = variable.emitter_lifetime - variable.emitter_age;"
      },
      "minecraft:emitter_rate_steady": {
        "spawn_rate": 20,
        "max_particles": 50
      },
      "minecraft:emitter_lifetime_expression": {
        "activation_expression": 1,
        "expiration_expression": 0
      },
      "minecraft:emitter_shape_point": {
        "offset": [0, 0.5, 0],
        "direction": [0, 1, 0]
      },
      "minecraft:particle_initial_speed": 0.3,
      "minecraft:particle_initial_spin": {
        "rotation": "Math.random(0, 360)",
        "rotation_rate": "Math.random(-180, 180)"
      },
      "minecraft:particle_lifetime_expression": {
        "max_lifetime": "variable.lifetime"
      },
      "minecraft:particle_motion_dynamic": {
        "linear_acceleration": [0, -0.1, 0],
        "linear_drag_coefficient": 0.1
      },
      "minecraft:particle_appearance_billboard": {
        "size": ["variable.size * (1 - variable.particle_age / variable.lifetime)", "variable.size * (1 - variable.particle_age / variable.lifetime)"],
        "facing_camera_mode": "rotate_xyz",
        "uv": {
          "texture_width": 16,
          "texture_height": 16,
          "flipbook": {
            "base_UV": [0, 0],
            "size_UV": [16, 16],
            "step_UV": [0, 0],
            "frames_per_second": 1,
            "max_frame": 1,
            "stretch_to_lifetime": true
          }
        }
      },
      "minecraft:particle_appearance_tinting": {
        "color": [0.3, 0.6, 1.0, "1 - variable.particle_age / variable.lifetime"]
      }
    }
  }
}
