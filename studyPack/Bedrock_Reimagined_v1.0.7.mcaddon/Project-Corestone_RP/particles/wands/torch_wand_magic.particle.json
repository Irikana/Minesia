{
  "format_version": "1.10.0",
  "particle_effect": {
    "description": {
      "identifier": "5fs_br:torch_wand_magic",
      "basic_render_parameters": {
        "material": "particles_add",
        "texture": "textures/particles/magic_particles/yuan_1"
      }
    },

    "curves": {
      "variable.size_curve": {
        "type": "linear",
        "input": "v.particle_age",
        "horizontal_range": "v.particle_lifetime",
        "nodes": [
          0.0, 0.0,
          0.10, 1.10,
          0.65, 1.05,
          1.0, 0.0
        ]
      }
    },

    "components": {
      "minecraft:emitter_rate_steady": {
        "spawn_rate": 18,
        "max_particles": 65
      },

      "minecraft:emitter_lifetime_once": {
        "active_time": 0.45
      },

      "minecraft:emitter_shape_point": {},

      "minecraft:particle_lifetime_expression": {
        "max_lifetime": "math.random(0.35, 0.75)"
      },

      "minecraft:particle_initial_spin": {
        "rotation": "math.random(0, 360)",
        "rotation_rate": "math.random(-280, 280)"
      },

      "minecraft:particle_initial_speed": "math.random(0.25, 0.7)",

      "minecraft:particle_motion_dynamic": {
        "linear_acceleration": [
          "math.random(-0.02, 0.02)",
          "math.random(0.04, 0.12)",
          "math.random(-0.02, 0.02)"
        ],
        "linear_drag_coefficient": 0.18
      },

      "minecraft:particle_appearance_billboard": {
        "size": [
          "0.70 * variable.size_curve * (0.5 + variable.particle_random_1)",
          "0.70 * variable.size_curve * (0.5 + variable.particle_random_1)"
        ],
        "facing_camera_mode": "rotate_xyz",
        "uv": {
          "texture_width": 16,
          "texture_height": 16,
          "uv": [0, 0],
          "uv_size": [16, 16]
        }
      },

      "minecraft:particle_appearance_tinting": {
        "color": {
          "interpolant": "v.particle_age / v.particle_lifetime",
          "gradient": {
            "0.0": "#FF9A40FF",
            "0.30": "#FF5A20FF",
            "1.0": "#FFFFFF00"
          }
        }
      }
    }
  }
}
