{
    "format_version": "1.10.0",
    "minecraft:client_entity": {
        "description": {
            "identifier": "5fs_br:finch_bird",
            "materials": {
                "default": "parrot"
            },
            "textures": {
                "bird_0": "textures/entity/mobs/birds/finch_bird_0",
                "bird_1": "textures/entity/mobs/birds/finch_bird_1",
                "bird_2": "textures/entity/mobs/birds/finch_bird_2"
            },
            "geometry": {
                "default": "geometry.finch_bird"
            },
            "scripts": {
                "pre_animation": [
