                "walk": "animation.finch_bird.walk",
                "fly": "animation.finch_bird.fly",
                "chirp": "animation.finch_bird.chirp",
                "chirp_transitioner": "animation.finch_bird.chirp_transitioner",
                "death": "animation.finch_bird.death",
                "general_controller": "controller.animation.bird.general",
                "chirp_controller": "controller.animation.bird.chirp",
                "root_controller": "controller.animation.bird.root"
            },
            "render_controllers": [
                "controller.render.bird"
            ],
            "spawn_egg": {
                "texture": "5fs_br:finch_bird_spawn_egg"
            }
        }
    }
}