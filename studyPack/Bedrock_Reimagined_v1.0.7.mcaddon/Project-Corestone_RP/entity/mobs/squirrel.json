                "death": "animation.squirrel.death",
                "climb": "animation.squirrel.climb",
                "general_controller": "controller.animation.squirrel.general",
                "climb_controller": "controller.animation.squirrel.climb",
                "look_at_target_controller": "controller.animation.squirrel.look_at_target",
                "root_controller": "controller.animation.squirrel.root"
            },
            "scripts": {
                "pre_animation": [
                    "t.variant = q.property('5fs_br:variant');",
