{
	"format_version": "1.8.0",
	"animations": {
		"animation.boat_geometry.move": {
			"loop": true,
			"animation_length": 1.12,
			"bones": {
				"paddle_right": {
					"rotation": {
						"0.0": [0, 0, 0],
						"1.12": [0, 0, 360]
					}
				},
				"paddle_left": {
					"rotation": {
						"0.0": [0, 0, 0],
						"1.12": [0, 0, 360]
					}
				}
			}
		},
		"animation.boat_geometry.death": {
			"loop": true,
			"animation_length": 0,
			"bones": {
				"boat": {
					"rotation": {
						"0.0": [0, 0, "Math.min(Math.sqrt(Math.max(0, q.anim_time * 20 - 0.5) / 20 * 1.6), 1) * -90"]
					}
				}
			}
		},
		"animation.boat_geometry.hurt": {
			"animation_length": 0.5,
			"bones": {
				"boat": {
					"rotation": {
						"0.0": ["(query.max_health - query.health)", 0, 0],
						"0.125": ["-(query.max_health - query.health)", 0, 0],
						"0.25": ["(query.max_health - query.health) / 2", 0, 0],
						"0.375": [" -(query.max_health - query.health) / 4", 0, 0],
						"0.5": [0, 0, 0]
					}
				}
			}
		},
		"animation.boat_geometry.in_bubble_column": {
			"loop": true,
			"animation_length": 0.75,
			"bones": {
				"boat": {
					"rotation": {
						"0.0": {
							"post": [90, -10, 80],
							"lerp_mode": "catmullrom"
						},
						"0.375": {
							"post": [90, 10, 100],
							"lerp_mode": "catmullrom"
						},
						"0.75": {
							"post": [90, -10, 80],
							"lerp_mode": "catmullrom"
						}
					}
				}
			}
		}
	}
}