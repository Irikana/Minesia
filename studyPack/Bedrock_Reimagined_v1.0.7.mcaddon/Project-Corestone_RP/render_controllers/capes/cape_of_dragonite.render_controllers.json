{
  "format_version": "1.20.0",
  "render_controllers": {
    "controller.render.cape_of_dragonite": {
      "geometry": "geometry.default",
      "arrays": {
        "textures": {
          "array.textures": [
            "Texture.dragonite0",
            "Texture.dragonite1",
            "Texture.dragonite2",
            "Texture.dragonite3",
            "Texture.dragonite4",
            "Texture.dragonite5",
            "Texture.dragonite6",
            "Texture.dragonite7",
            "Texture.dragonite8",
            "Texture.dragonite9",
            "Texture.dragonite10",
            "Texture.dragonite11",
            "Texture.dragonite12"
          ]
        }
      },
      "materials": [
        {
          "*": "variable.is_enchanted?material.enchanted:material.default"
        }
      ],
      "textures": [
        "temp.life_time=query.life_time*8;return array.textures[temp.life_time];",
        "texture.enchanted"
      ]
    }
  }
}