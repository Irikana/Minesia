{
  "format_version": "1.20.0",
  "render_controllers": {
    "controller.render.cape_of_crystalline": {
      "geometry": "geometry.default",
      "arrays": {
        "textures": {
          "array.textures": [
            "Texture.crystalline0",
            "Texture.crystalline1",
            "Texture.crystalline2",
            "Texture.crystalline3",
            "Texture.crystalline4",
            "Texture.crystalline5",
            "Texture.crystalline6",
            "Texture.crystalline7"
          ]
        }
      },
      "materials": [
        {
          "*": "variable.is_enchanted?material.enchanted:material.default"
        }
      ],
      "textures": [
        "temp.life_time=query.life_time*8;return array.textures[temp.life_time];",
        "texture.enchanted"
      ]
    }
  }
}