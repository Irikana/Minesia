{
  "format_version": "1.20.0",
  "render_controllers": {
    "controller.render.cape_of_furnace": {
      "geometry": "geometry.default",
      "arrays": {
        "textures": {
          "array.textures": [
            "Texture.furnace0",
            "Texture.furnace1",
            "Texture.furnace2",
            "Texture.furnace3",
            "Texture.furnace4",
            "Texture.furnace5",
            "Texture.furnace6",
            "Texture.furnace7"
          ]
        }
      },
      "materials": [
        {
          "*": "variable.is_enchanted?material.enchanted:material.default"
        }
      ],
      "textures": [
        "temp.life_time=query.life_time*8;return array.textures[temp.life_time];",
        "texture.enchanted"
      ]
    }
  }
}