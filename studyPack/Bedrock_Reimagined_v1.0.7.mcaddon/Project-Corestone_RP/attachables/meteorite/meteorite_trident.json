            "materials": {
                "default": "entity_alphatest"
            },
            "textures": {
                "default": "textures/entity/gears/meteorite_trident"
            },
            "geometry": {
                "default": "geometry.meteorite_tridentv2"
            },
            "animations": {
                "controller": "controller.animation.trident_general_5fs",
                "fpp_idle": "animation.trident.fpp_idle_5fs",
                "tpp_hold": "animation.trident.tpp_hold_5fs",
                "fpp_ability": "animation.trident.fpp_spear_being_thrown_5fs",
                "tpp_ability": "animation.trident.tpp_throw"
            },
            "render_controllers": [
                        "controller.render.default"
            ],
            "scripts": {
                "animate": [
                "controller",
                {
                    "tpp_hold": "!c.is_first_person"
                },
                {
                    "tpp_ability": "!c.is_first_person && q.cooldown_time_remaining('slot.weapon.mainhand') > 0"
                }
                ]
            }
        }
    }
