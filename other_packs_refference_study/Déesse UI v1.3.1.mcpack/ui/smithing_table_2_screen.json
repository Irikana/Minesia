{
	"toolbar_panel/toolbar_background/toolbar_stack_panel/help_button_panel": {
		"ignored": true
	},
	"toolbar_panel": {
		"bindings": [
			{
				"binding_name": "#close_button_visible",
				"binding_name_override": "#visible"
			}
		]
	},
	"smithing_table_panel/root_panel/smithing_table_screen_inventory": {
		"bindings": [
			{
				"binding_type": "view",
				"source_control_name": "smithing_preview_tog",
				"source_property_name": "(not #toggle_state)",
				"target_property_name": "#visible"
			}
		]
	},
	"smithing_table_panel/root_panel": {
		"modifications": [
			{
				"array_name": "controls",
				"operation": "insert_front",
				"value": [
					{
						"quick_container@déesse_qcMain.content_panel": {}
					},
					{
						"hover_fix@déesse_hoverFix.button": {}
					},
					{
						"smithing_armor_preview_panel@déesse_smithingPreview.smithing_armor_preview_panel": {}
					},
					{
						"smithing_armor_preview_button@déesse_smithingPreview.smithing_armor_preview_button": {}
					}
				]
			}
		]
	},
	"smithing_table_panel": {
		"modifications": [
			{
				"array_name": "controls",
				"operation": "insert_front",
				"value": [
					{
						"smithing_preview_screen@déesse_defs.variables": {
							"type": "panel",
							"controls": [
								{
									"amithing_armor_buttn@déesse_smithingArmorPreview.amithing_armor_buttn": {
										"ignored": "$is_performance_mode"
									}
								},
								{
									"smithing_armor_preview_screen@déesse_common.panel_factory": {
										"ignored": "$is_performance_mode",
										"$child_controls": "déesse_ui_tools.smithing_armor_preview_screen",
										"$toggle_binding_name": "smithing_armor_preview_toggle"
									}
								}
							]
						}
					}
				]
			}
		]
	},
	"smithing_table_2_screen": {
		"force_render_below": "$dé:force_render_below"
	}
}