{
	"file_signature": "Itzriyo157",
	"namespace": "déesse_enchanting",
	"enchantment_panel": {
		"type": "stack_panel",
		"size": [
			"100%",
			"100%"
		],
		"collection_name": "#enchant_buttons",
		"controls": [
			{
				"enchant_0@déesse_enchanting.enchant_button_panel": {
					"$id": 0
				}
			},
			{
				"enchant_1@déesse_enchanting.enchant_button_panel": {
					"$id": 1
				}
			},
			{
				"enchant_2@déesse_enchanting.enchant_button_panel": {
					"$id": 2
				}
			}
		]
	},
	"check_button_panel": {
		"type": "panel",
		"size": [
			32,
			12
		],
		"anchor_from": "left_middle",
		"anchor_to": "left_middle",
		"offset": [
			17,
			-11
		],
		"controls": [
			{
				"enchant_select@déesse_common.input_raw_toggle": {
					"$toggle_name": "enchant_item",
					"$toggle_view_binding_name": "unselect_item_tog",
					"$radio_toggle_group": true,
					"$toggle_group_forced_index": 0,
					"$toggle_sound_volume": 0,
					"layer": 3
				}
			},
			{
				"input": {
					"type": "collection_panel",
					"collection_name": "#enchant_buttons",
					"layer": 3,
					"controls": [
						{
							"enchant_0@enchant_button_input": {
								"$id": 0
							}
						},
						{
							"enchant_1@enchant_button_input": {
								"$id": 1
							}
						},
						{
							"enchant_2@enchant_button_input": {
								"$id": 2
							}
						}
					]
				}
			},
			{
				"button@common_buttons.light_text_button": {
					"$pressed_button_name": "button.none",
					"$border_visible": false,
					"consume_hover_events": false
				}
			}
		],
		"bindings": [
			{
				"binding_name": "#open",
				"binding_type": "global"
			},
			{
				"binding_type": "view",
				"source_control_name": "unselect_item_tog",
				"source_property_name": "#toggle_state",
				"target_property_name": "#toggle"
			},
			{
				"binding_type": "view",
				"source_property_name": "(#open and not #toggle)",
				"target_property_name": "#visible"
			}
		]
	},
	"enchant_select_toggle@déesse_common.input_raw_toggle": {
		"$toggle_name": "enchant_item",
		"$toggle_view_binding_name": "('select_enchant_' + $id)",
		"$toggle_group_forced_index": "($id + 1)",
		"$radio_toggle_group": true,
		"$unchecked_control": "déesse_enchanting.enchant_select_unchecked",
		"$unchecked_hover_control": "déesse_enchanting.enchant_select_unchecked_hover",
		"$checked_control": "déesse_enchanting.enchant_select_checked",
		"$checked_hover_control": "déesse_enchanting.enchant_select_checked_hover",
		"$unchecked_locked_control": "déesse_enchanting.enchant_select_locked",
		"$checked_locked_control": "déesse_enchanting.enchant_select_locked",
		"$unchecked_locked_hover_control": "déesse_enchanting.enchant_select_locked",
		"$checked_locked_hover_control": "déesse_enchanting.enchant_select_locked",
		"layer": 24,
		"bindings": [
			{
				"binding_name": "#selectable_button_visibility",
				"binding_name_override": "#enabled",
				"binding_collection_name": "#enchant_buttons",
				"binding_type": "collection"
			},
			{
				"binding_name": "#open",
				"binding_name_override": "#visible",
				"binding_type": "global"
			}
		],
		"size": [
			"100%",
			"100%"
		]
	},
	"enchant_cost@enchanting.enchant_cost": {
		"color": "$clr",
		"$clr|default": "$enchanting_cost_success_color"
	},
	"checked_background@enchanting.enchanting_image": {
		"texture": "textures/ui/enchanting_active_background_with_hover_text"
	},
	"enchant_select_locked@enchant_select_unchecked": {
		"$bg_control": "enchanting.dark_background",
		"$clr": "$enchanting_cost_fail_color"
	},
	"enchant_select_checked_hover@enchant_select_checked": {
		"$is_hover_state": true
	},
	"enchant_select_checked@enchant_select_unchecked": {
		"$bg_control": "déesse_enchanting.checked_background"
	},
	"enchant_select_unchecked_hover@enchant_select_unchecked": {
		"$is_hover_state": true
	},
	"enchant_select_unchecked": {
		"type": "panel",
		"$is_hover_state|default": false,
		"$bg_control|default": "enchanting.active_background",
		"controls": [
			{
				"bg@$bg_control": {
					"layer": 0
				}
			},
			{
				"rune_text@enchanting.fail_runes": {
					"layer": 1
				}
			},
			{
				"enchant_cost@déesse_enchanting.enchant_cost": {
					"layer": 1
				}
			},
			{
				"hover_text@common.hover_text": {
					"ignored": "(not $is_hover_state)",
					"bindings": [
						{
							"binding_type": "collection",
							"binding_name": "#hover_text",
							"binding_collection_name": "#enchant_buttons"
						}
					]
				}
			}
		]
	},
	"enchant_button_panel": {
		"type": "panel",
		"size": [
			"100%",
			"fill"
		],
		"layer": 7,
		"collection_index": "$id",
		"controls": [
			{
				"dark_background@enchanting.dark_background": {}
			},
			{
				"enchant_select_toggle@déesse_enchanting.enchant_select_toggle": {}
			}
		]
	},
	"enchant_button_input": {
		"type": "button",
		"collection_index": "$id",
		"consume_hover_events": false,
		"bindings": [
			{
				"binding_type": "collection_details",
				"binding_collection_name": "#enchant_buttons"
			},
			{
				"binding_type": "view",
				"source_control_name": "('select_enchant_' + $id)",
				"source_property_name": "#toggle_state",
				"target_property_name": "#toggle"
			},
			{
				"binding_name": "#selectable_button_visibility",
				"binding_collection_name": "#enchant_buttons",
				"binding_type": "collection"
			},
			{
				"binding_type": "view",
				"source_property_name": "(#toggle and #selectable_button_visibility)",
				"target_property_name": "#visible"
			}
		],
		"button_mappings": [
			{
				"from_button_id": "button.menu_select",
				"to_button_id": "button.menu_ok",
				"mapping_type": "pressed",
				"consume_event": false
			},
			{
				"from_button_id": "button.menu_ok",
				"to_button_id": "button.menu_ok",
				"mapping_type": "focused",
				"consume_event": false
			},
			{
				"from_button_id": "button.controller_back",
				"to_button_id": "button.menu_ok",
				"mapping_type": "focused",
				"consume_event": false,
				"ignored": "(not $is_ps4)"
			}
		]
	},
	"xp_number_label": {
		"type": "label",
		"text": "#text",
		"size": [
			"default",
			"default"
		],
		"layer": 9,
		"color": "#color",
		"bindings": [
			{
				"binding_name": "#player_level_info",
				"binding_name_override": "#text"
			},
			{
				"binding_name": "#player_level_color",
				"binding_name_override": "#color"
			}
		]
	},
	"border_xp_number_label@xp_number_label": {
		"layer": 6,
		"color": [
			0,
			0,
			0
		],
		"bindings": [
			{
				"binding_name": "#player_level_info",
				"binding_name_override": "#text"
			}
		]
	},
